<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Fitness_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Fitness_App"
    xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
    xmlns:pages="clr-namespace:Fitness_App.Pages"
    Title="Fitness_App"
    FlyoutBehavior="Disabled">

    <ShellContent
        Title="Loading"
        Route="loading"
        ContentTemplate="{DataTemplate pages:LoadingPage}" />

    <ShellContent
        Title="Login"
        Route="login"
        ContentTemplate="{DataTemplate pages:LoginPage}" />

    <ShellContent
        Title="Register"
        Route="register"
        ContentTemplate="{DataTemplate pages:RegisterPage}" />

    <ShellContent
        Title="Email Verification"
        Route="emailverification"
        ContentTemplate="{DataTemplate pages:EmailVerificationPage}" />

    <ShellContent
        Title="Profile Setup"
        Route="profilesetup"
        ContentTemplate="{DataTemplate pages:ProfileSetupPage}" />

    <TabBar Route="main">
        <ShellContent
            Title="Home"
            Route="home"
            ContentTemplate="{DataTemplate pages:HomePage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialSymbols" Glyph="{x:Static icons:MaterialSymbols.Home}" Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Maps"
            Route="maps"
            ContentTemplate="{DataTemplate pages:MapsPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialSymbols" Glyph="{x:Static icons:MaterialSymbols.Map}" Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Record"
            Route="record"
            ContentTemplate="{DataTemplate pages:RecordPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialSymbols" Glyph="{x:Static icons:MaterialSymbols.Play_circle}" Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="You"
            Route="you"
            ContentTemplate="{DataTemplate pages:YouPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialSymbols" Glyph="{x:Static icons:MaterialSymbols.Person}" Size="24" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
