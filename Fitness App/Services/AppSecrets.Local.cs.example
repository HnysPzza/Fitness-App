// Copy this file to AppSecrets.Local.cs and fill in your local values.
// AppSecrets.Local.cs is ignored by git.

namespace Fitness_App.Services;

internal static partial class SupabaseConfig
{
    static partial void ConfigureLocal(ref string url, ref string anonKey)
    {
        url = "https://your-project.supabase.co";
        anonKey = "your-supabase-anon-key";
    }
}

internal static partial class MapboxConfig
{
    static partial void ConfigureLocal(ref string accessToken)
    {
        accessToken = "your-mapbox-public-token";
    }
}
