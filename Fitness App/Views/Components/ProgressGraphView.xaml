<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             xmlns:viewmodels="clr-namespace:Fitness_App.ViewModels"
             xmlns:models="clr-namespace:Fitness_App.Models"
             x:Class="Fitness_App.Views.Components.ProgressGraphView"
             x:Name="RootView">
    
    <ContentView.BindingContext>
        <viewmodels:ProgressGraphViewModel />
    </ContentView.BindingContext>

    <Border x:Name="ProgressCard"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="{AppThemeBinding Light=#0F172A, Dark=#000000}" 
                    Radius="20" 
                    Opacity="0.1" 
                    Offset="0,6" />
        </Border.Shadow>

        <VerticalStackLayout Padding="24" Spacing="20">
            <!-- Header -->
            <Label Text="Your Progress" 
                   FontSize="18" 
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />

            <!-- Period Toggle -->
            <Border StrokeThickness="0"
                    Padding="4"
                    BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#0F172A}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                    <Border x:Name="TodayTab">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTodayTapped" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Today}">
                                <Setter Property="BackgroundColor" Value="#FC5200" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label Text="Today" 
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Padding="8">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Today}">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Week}">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Month}">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <Border Grid.Column="1" x:Name="WeekTab">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnWeekTapped" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Week}">
                                <Setter Property="BackgroundColor" Value="#10B981" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label Text="Week" 
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Padding="8">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Week}">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Today}">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Month}">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <Border Grid.Column="2" x:Name="MonthTab">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMonthTapped" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Month}">
                                <Setter Property="BackgroundColor" Value="#2563EB" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label Text="Month" 
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Padding="8">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Month}">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Today}">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" 
                                           Binding="{Binding SelectedPeriod}" 
                                           Value="{x:Static models:ProgressPeriod.Week}">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                </Grid>
            </Border>

            <!-- LiveCharts Graph -->
            <lvc:CartesianChart Series="{Binding Series}"
                              HeightRequest="180"
                              AnimationsSpeed="00:00:00.500"
                              LegendPosition="Hidden"
                              TooltipPosition="Hidden">
                <lvc:CartesianChart.XAxes>
                    <lvc:Axis IsVisible="False" />
                </lvc:CartesianChart.XAxes>
                <lvc:CartesianChart.YAxes>
                    <lvc:Axis IsVisible="False" />
                </lvc:CartesianChart.YAxes>
            </lvc:CartesianChart>

            <!-- Stats Display -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Today" 
                           FontSize="12"
                           Opacity="0.6"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    <Label Text="{Binding TodayValue, StringFormat='{0:F1}'}" 
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Today}">
                                <Setter Property="TextColor" Value="#FC5200" />
                                <Setter Property="FontSize" Value="24" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Week}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Month}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="Week" 
                           FontSize="12"
                           Opacity="0.6"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    <Label Text="{Binding WeekValue, StringFormat='{0:F1}'}" 
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Week}">
                                <Setter Property="TextColor" Value="#10B981" />
                                <Setter Property="FontSize" Value="24" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Today}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Month}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" Spacing="4">
                    <Label Text="Month" 
                           FontSize="12"
                           Opacity="0.6"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    <Label Text="{Binding MonthValue, StringFormat='{0:F1}'}" 
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Month}">
                                <Setter Property="TextColor" Value="#2563EB" />
                                <Setter Property="FontSize" Value="24" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Today}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" 
                                       Binding="{Binding SelectedPeriod}" 
                                       Value="{x:Static models:ProgressPeriod.Week}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>
