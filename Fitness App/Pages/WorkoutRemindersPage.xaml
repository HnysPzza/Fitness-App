<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.WorkoutRemindersPage"
             Title="Workout Reminders"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Workout Reminders"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Stay consistent with scheduled nudges for the days and times you actually train."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Enable reminders"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#F8FAFC" />
                        <Label Text="Control all workout reminder nudges from one place."
                               FontSize="13"
                               TextColor="#94A3B8" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            x:Name="EnableSwitch"
                            OnColor="#FC5200"
                            VerticalOptions="Center"
                            Toggled="OnEnableToggled" />
                </Grid>
            </Border>

            <!-- Settable content (grays out when disabled) -->
            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout x:Name="RemindersContent" Spacing="0">

                <!-- Reminder Time -->
                <Grid Padding="18,14" MinimumHeightRequest="72">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTimeTapped" />
                    </Grid.GestureRecognizers>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Reminder Time" FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#F8FAFC"
                               VerticalOptions="Center" />
                        <Label Text="Choose when your reminder should arrive"
                               FontSize="12"
                               TextColor="#94A3B8" />
                    </VerticalStackLayout>
                    <StackLayout Grid.Column="1" Orientation="Horizontal" VerticalOptions="Center" Spacing="4">
                        <Label x:Name="TimeLabel" Text="7:00 AM" FontSize="15" TextColor="#F8FAFC" VerticalOptions="Center" />
                        <Label Text="›" FontSize="22" TextColor="#64748B" VerticalOptions="Center" />
                    </StackLayout>
                </Grid>
                <BoxView Style="{StaticResource DividerStyle}" />

                <!-- Repeat Days -->
                <Grid Padding="18,14" MinimumHeightRequest="72">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDaysTapped" />
                    </Grid.GestureRecognizers>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                        <Label Text="Repeat" FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#F8FAFC" />
                        <Label x:Name="DaysLabel" Text="Mon, Wed, Fri" FontSize="13" TextColor="#94A3B8" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="22" TextColor="#64748B" VerticalOptions="Center" />
                </Grid>
                <BoxView Style="{StaticResource DividerStyle}" />

                <!-- Reminder Message -->
                <Grid Padding="18,14" MinimumHeightRequest="72">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMessageTapped" />
                    </Grid.GestureRecognizers>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                        <Label Text="Reminder Message" FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#F8FAFC" />
                        <Label x:Name="MessageLabel" Text="Time to get moving!" FontSize="13" TextColor="#94A3B8" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="22" TextColor="#64748B" VerticalOptions="Center" />
                </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
