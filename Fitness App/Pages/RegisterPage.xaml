<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:vm="clr-namespace:Fitness_App.ViewModels"
             x:Class="Fitness_App.Pages.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0B0F19}">

    <ScrollView>
        <Grid Padding="28,0" RowSpacing="0"
              VerticalOptions="Center"
              MinimumHeightRequest="800">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- LOGO -->
            <VerticalStackLayout Grid.Row="0" Spacing="8"
                                 HorizontalOptions="Center" Margin="0,48,0,28">
                <Border HeightRequest="68" WidthRequest="68" StrokeThickness="0"
                        HorizontalOptions="Center">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FC5200" Offset="0" />
                            <GradientStop Color="#FF8C42" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#FC5200" Radius="24" Opacity="0.3" Offset="0,6" />
                    </Border.Shadow>
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Directions_run}"
                                       FontSize="34" TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="StrideX" FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
            </VerticalStackLayout>

            <!-- HEADING -->
            <VerticalStackLayout Grid.Row="1" Spacing="6" Margin="0,0,0,24">
                <Label Text="Create your account" FontSize="22" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                <Label Text="Start tracking your fitness journey" FontSize="14" Opacity="0.65"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />
            </VerticalStackLayout>

            <!-- EMAIL -->
            <VerticalStackLayout Grid.Row="2" Spacing="6" Margin="0,0,0,14">
                <Label Text="Email" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />
                <Border StrokeThickness="1.5" Padding="14,0" HeightRequest="52"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Email}"
                                           FontSize="20" Opacity="0.5" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        <Entry Grid.Column="1" Placeholder="you@example.com" Keyboard="Email"
                               ReturnType="Next" Text="{Binding Email}" FontSize="15"
                               VerticalOptions="Center"
                               PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#475569}"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    </Grid>
                </Border>
                <Label Text="{Binding EmailError}"
                       IsVisible="{Binding EmailError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12" TextColor="#EF4444" Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- PASSWORD -->
            <VerticalStackLayout Grid.Row="3" Spacing="6" Margin="0,0,0,14">
                <Label Text="Password" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />
                <Border StrokeThickness="1.5" Padding="14,0" HeightRequest="52"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Lock}"
                                           FontSize="20" Opacity="0.5" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        <Entry Grid.Column="1" Placeholder="Min. 8 characters"
                               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                               ReturnType="Next" Text="{Binding Password}" FontSize="15"
                               VerticalOptions="Center"
                               PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#475569}"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                        <controls:IconLabel Grid.Column="2"
                                           Text="{x:Static icons:MaterialSymbols.Visibility}"
                                           FontSize="20" Opacity="0.5" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}">
                            <controls:IconLabel.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                            </controls:IconLabel.GestureRecognizers>
                        </controls:IconLabel>
                    </Grid>
                </Border>
                <Label Text="{Binding PasswordError}"
                       IsVisible="{Binding PasswordError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12" TextColor="#EF4444" Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- CONFIRM PASSWORD -->
            <VerticalStackLayout Grid.Row="4" Spacing="6" Margin="0,0,0,12">
                <Label Text="Confirm Password" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />
                <Border StrokeThickness="1.5" Padding="14,0" HeightRequest="52"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Lock}"
                                           FontSize="20" Opacity="0.5" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        <Entry Grid.Column="1" Placeholder="Re-enter password"
                               IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                               ReturnType="Go" Text="{Binding ConfirmPassword}" FontSize="15"
                               VerticalOptions="Center"
                               PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#475569}"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                        <controls:IconLabel Grid.Column="2"
                                           Text="{x:Static icons:MaterialSymbols.Visibility}"
                                           FontSize="20" Opacity="0.5" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}">
                            <controls:IconLabel.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}" />
                            </controls:IconLabel.GestureRecognizers>
                        </controls:IconLabel>
                    </Grid>
                </Border>
                <Label Text="{Binding ConfirmPasswordError}"
                       IsVisible="{Binding ConfirmPasswordError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12" TextColor="#EF4444" Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- GENERAL ERROR -->
            <Border Grid.Row="5"
                    IsVisible="{Binding GeneralError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                    StrokeThickness="0" BackgroundColor="#1AEF4444" Padding="14,10" Margin="0,0,0,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <HorizontalStackLayout Spacing="10">
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Warning}"
                                       FontSize="18" TextColor="#EF4444" VerticalOptions="Center" />
                    <Label Text="{Binding GeneralError}" FontSize="13" TextColor="#EF4444"
                           VerticalOptions="Center" LineBreakMode="WordWrap"
                           HorizontalOptions="FillAndExpand" />
                </HorizontalStackLayout>
            </Border>

            <!-- SIGN UP BUTTON -->
            <Grid Grid.Row="6" Margin="0,4,0,20">
                <Button Text="Sign Up" FontSize="17" FontAttributes="Bold"
                        TextColor="White" HeightRequest="56" CornerRadius="16"
                        Command="{Binding SignUpCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FC5200" Offset="0" />
                            <GradientStop Color="#FF6B35" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Shadow>
                        <Shadow Brush="#FC5200" Radius="25" Opacity="0.4" Offset="0,8" />
                    </Button.Shadow>
                </Button>
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="White" HeightRequest="28" WidthRequest="28"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- DIVIDER -->
            <Grid Grid.Row="7" ColumnDefinitions="*,Auto,*" Margin="0,0,0,20">
                <BoxView HeightRequest="1" VerticalOptions="Center"
                         Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />
                <Label Grid.Column="1" Text="  or  " FontSize="13"
                       TextColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}" />
                <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center"
                         Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />
            </Grid>

            <!-- GOOGLE BUTTON -->
            <Border Grid.Row="8" StrokeThickness="1.5" HeightRequest="56"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Margin="0,0,0,28">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoogleSignUpTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                    <Label Text="G" FontSize="22" FontAttributes="Bold"
                           VerticalOptions="Center" TextColor="#4285F4" />
                    <Label Text="Continue with Google" FontSize="15" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                </HorizontalStackLayout>
            </Border>

            <!-- FOOTER -->
            <HorizontalStackLayout Grid.Row="9" HorizontalOptions="Center"
                                   Spacing="4" Margin="0,0,0,36">
                <Label Text="Already have an account?" FontSize="13"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}" />
                <Label Text="Sign in" FontSize="13" FontAttributes="Bold"
                       VerticalOptions="Center" TextColor="#FC5200">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
