<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:vm="clr-namespace:Fitness_App.ViewModels"
             x:Class="Fitness_App.Pages.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#16171B">

    <ScrollView>
        <Grid Padding="28,0" RowSpacing="0"
              VerticalOptions="Center"
              MinimumHeightRequest="860">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><!-- 0: Brand -->
                <RowDefinition Height="Auto" /><!-- 1: Heading -->
                <RowDefinition Height="Auto" /><!-- 2: Email -->
                <RowDefinition Height="Auto" /><!-- 3: Password label -->
                <RowDefinition Height="Auto" /><!-- 4: Password field -->
                <RowDefinition Height="Auto" /><!-- 5: Confirm label -->
                <RowDefinition Height="Auto" /><!-- 6: Confirm field -->
                <RowDefinition Height="Auto" /><!-- 7: General error -->
                <RowDefinition Height="Auto" /><!-- 8: Sign Up button -->
                <RowDefinition Height="Auto" /><!-- 9: Divider -->
                <RowDefinition Height="Auto" /><!-- 10: Google button -->
                <RowDefinition Height="Auto" /><!-- 11: Footer -->
                <RowDefinition Height="Auto" /><!-- 12: Copyright -->
            </Grid.RowDefinitions>

            <!-- ═══ BRAND NAME ═══ -->
            <Label Grid.Row="0"
                   Text="STRIDEX"
                   FontFamily="OpenSansBold"
                   FontSize="22"
                   FontAttributes="Italic"
                   TextColor="#FC5200"
                   HorizontalOptions="Center"
                   Margin="0,52,0,36" />

            <!-- ═══ HEADING ═══ -->
            <VerticalStackLayout Grid.Row="1" Spacing="8" Margin="0,0,0,28" HorizontalOptions="Center">
                <Label Text="Create your account"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#FFFFFF" />
                <Label Text="Start tracking your fitness journey today."
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#FC5200" />
            </VerticalStackLayout>

            <!-- ═══ EMAIL INPUT ═══ -->
            <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,0,0,16">
                <Label Text="EMAIL ADDRESS"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#94A3B8" />
                <Border StrokeThickness="0" Padding="16,0" HeightRequest="54" BackgroundColor="#1E1F23">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Email}"
                                           FontSize="20" Opacity="0.6" VerticalOptions="Center"
                                           TextColor="#94A3B8" />
                        <Entry Grid.Column="1" Placeholder="runner@stridex.io" Keyboard="Email"
                               ReturnType="Next" Text="{Binding Email}" FontSize="15"
                               VerticalOptions="Center" BackgroundColor="Transparent"
                               PlaceholderColor="#4A4B52" TextColor="#FFFFFF" />
                    </Grid>
                </Border>
                <Label Text="{Binding EmailError}"
                       IsVisible="{Binding EmailError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12" TextColor="#EF4444" Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- ═══ PASSWORD LABEL ═══ -->
            <Label Grid.Row="3"
                   Text="PASSWORD"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#94A3B8"
                   Margin="0,0,0,8" />

            <!-- ═══ PASSWORD FIELD ═══ -->
            <VerticalStackLayout Grid.Row="4" Spacing="8" Margin="0,0,0,16">
                <Border StrokeThickness="0" Padding="16,0" HeightRequest="54" BackgroundColor="#1E1F23">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Lock}"
                                           FontSize="20" Opacity="0.6" VerticalOptions="Center"
                                           TextColor="#94A3B8" />
                        <Entry Grid.Column="1" Placeholder="············"
                               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                               ReturnType="Next" Text="{Binding Password}" FontSize="15"
                               VerticalOptions="Center" BackgroundColor="Transparent"
                               PlaceholderColor="#4A4B52" TextColor="#FFFFFF" />
                        <controls:IconLabel Grid.Column="2"
                                           Text="{x:Static icons:MaterialSymbols.Visibility}"
                                           FontSize="20" Opacity="0.5" VerticalOptions="Center"
                                           TextColor="#94A3B8">
                            <controls:IconLabel.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                            </controls:IconLabel.GestureRecognizers>
                        </controls:IconLabel>
                    </Grid>
                </Border>
                <Label Text="{Binding PasswordError}"
                       IsVisible="{Binding PasswordError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12" TextColor="#EF4444" Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- ═══ CONFIRM PASSWORD LABEL ═══ -->
            <Label Grid.Row="5"
                   Text="CONFIRM PASSWORD"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#94A3B8"
                   Margin="0,0,0,8" />

            <!-- ═══ CONFIRM PASSWORD FIELD ═══ -->
            <VerticalStackLayout Grid.Row="6" Spacing="8" Margin="0,0,0,24">
                <Border StrokeThickness="0" Padding="16,0" HeightRequest="54" BackgroundColor="#1E1F23">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Lock}"
                                           FontSize="20" Opacity="0.6" VerticalOptions="Center"
                                           TextColor="#94A3B8" />
                        <Entry Grid.Column="1" Placeholder="············"
                               IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                               ReturnType="Go" Text="{Binding ConfirmPassword}" FontSize="15"
                               VerticalOptions="Center" BackgroundColor="Transparent"
                               PlaceholderColor="#4A4B52" TextColor="#FFFFFF" />
                        <controls:IconLabel Grid.Column="2"
                                           Text="{x:Static icons:MaterialSymbols.Visibility}"
                                           FontSize="20" Opacity="0.5" VerticalOptions="Center"
                                           TextColor="#94A3B8">
                            <controls:IconLabel.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}" />
                            </controls:IconLabel.GestureRecognizers>
                        </controls:IconLabel>
                    </Grid>
                </Border>
                <Label Text="{Binding ConfirmPasswordError}"
                       IsVisible="{Binding ConfirmPasswordError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12" TextColor="#EF4444" Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- ═══ GENERAL ERROR ═══ -->
            <Border Grid.Row="7"
                    IsVisible="{Binding GeneralError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                    StrokeThickness="0" BackgroundColor="#1AEF4444" Padding="14,10" Margin="0,0,0,16">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <HorizontalStackLayout Spacing="10">
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Warning}"
                                       FontSize="18" TextColor="#EF4444" VerticalOptions="Center" />
                    <Label Text="{Binding GeneralError}" FontSize="13" TextColor="#EF4444"
                           VerticalOptions="Center" LineBreakMode="WordWrap"
                           HorizontalOptions="FillAndExpand" />
                </HorizontalStackLayout>
            </Border>

            <!-- ═══ SIGN UP BUTTON ═══ -->
            <Grid Grid.Row="8" Margin="0,0,0,28">
                <Border HeightRequest="54" StrokeThickness="0"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FC5200" Offset="0" />
                            <GradientStop Color="#FF6B35" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#FC5200" Radius="20" Opacity="0.45" Offset="0,6" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SignUpCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                        <Label Text="CREATE ACCOUNT"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Chevron_right}"
                                           FontSize="20"
                                           TextColor="White"
                                           VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="White" HeightRequest="28" WidthRequest="28"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- ═══ DIVIDER ═══ -->
            <Grid Grid.Row="9" ColumnDefinitions="*,Auto,*" Margin="0,0,0,20">
                <BoxView HeightRequest="1" VerticalOptions="Center" Color="#2A2B30" />
                <Label Grid.Column="1"
                       Text="  OR CONTINUE WITH  "
                       FontSize="11" FontAttributes="Bold"
                       TextColor="#4A4B52" />
                <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center" Color="#2A2B30" />
            </Grid>

            <!-- ═══ GOOGLE BUTTON ═══ -->
            <Border Grid.Row="10" StrokeThickness="1" HeightRequest="54"
                    Stroke="#2A2B30" BackgroundColor="#1E1F23" Margin="0,0,0,32">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoogleSignUpTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                    <Border HeightRequest="26" WidthRequest="26" StrokeThickness="0" BackgroundColor="#FFFFFF">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                        <Label Text="G" FontSize="16" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="#4285F4" />
                    </Border>
                    <Label Text="Google Account"
                           FontSize="15" FontAttributes="Bold"
                           VerticalOptions="Center" TextColor="#FFFFFF" />
                </HorizontalStackLayout>
            </Border>

            <!-- ═══ FOOTER ═══ -->
            <HorizontalStackLayout Grid.Row="11" HorizontalOptions="Center" Spacing="4" Margin="0,0,0,20">
                <Label Text="Already have an account?"
                       FontSize="14" VerticalOptions="Center" TextColor="#6B7280" />
                <Label Text="Sign In"
                       FontSize="14" FontAttributes="Bold"
                       VerticalOptions="Center" TextColor="#FC5200">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <!-- ═══ COPYRIGHT ═══ -->
            <Label Grid.Row="12"
                   Text="© 2024 STRIDEX PERFORMANCE SYSTEMS"
                   FontSize="10"
                   HorizontalOptions="Center"
                   TextColor="#333540"
                   Margin="0,0,0,32" />

        </Grid>
    </ScrollView>
</ContentPage>
