<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.SwitchAccountPage"
             Title="Switch Account"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="#64748B" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="0,0,0,8" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Switch Account"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Move between saved accounts quickly while keeping your active profile clear."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Signed In As" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <!-- Current account -->
            <Grid Padding="18,14" MinimumHeightRequest="78">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                        BackgroundColor="#FC5200" StrokeThickness="0" VerticalOptions="Center" Margin="0,0,12,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                    <Label Text="J" TextColor="White" FontSize="20" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="John Dela Cruz" FontSize="16" FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="john@email.com" FontSize="13" TextColor="#94A3B8" />
                </VerticalStackLayout>
                <Label Grid.Column="2" Text="◉" FontSize="22" TextColor="#FC5200" VerticalOptions="Center" />
            </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Other accounts -->
            <Label Text="Other Accounts" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <Grid Padding="18,14" MinimumHeightRequest="78">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSwitchAccount" CommandParameter="jane@email.com" />
                </Grid.GestureRecognizers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                        BackgroundColor="#2196F3" StrokeThickness="0" VerticalOptions="Center" Margin="0,0,12,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                    <Label Text="J" TextColor="White" FontSize="20" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="Jane Dela Cruz" FontSize="16"
                           TextColor="#F8FAFC" />
                    <Label Text="jane@email.com" FontSize="13" TextColor="#94A3B8" />
                </VerticalStackLayout>
                <Label Grid.Column="2" Text="○" FontSize="22" TextColor="#475569" VerticalOptions="Center" />
            </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Add Account -->
            <Button Text="+ Add Account"
                    Clicked="OnAddAccount"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="16"
                    HeightRequest="48"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
