<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.SwitchAccountPage"
             Title="Switch Account"
             BackgroundColor="{AppThemeBinding Light=#F6F8FB, Dark=#0B0F19}">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="0,0,0,8" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Switch Account"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    <Label Text="Use another account saved on this phone without entering its password again."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Signed In As" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <VerticalStackLayout x:Name="CurrentAccountLayout" Spacing="0" />
            </Border>

            <Label Text="Saved On This Phone" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <VerticalStackLayout x:Name="SavedAccountsLayout" Spacing="0" />
            </Border>

            <Label x:Name="EmptyAccountsLabel"
                   Text="No other saved accounts yet. Add an account once, then it will appear here for quick switching."
                   FontSize="13"
                   LineBreakMode="WordWrap"
                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />

            <Button Text="+ Add Account"
                    Clicked="OnAddAccount"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="16"
                    HeightRequest="48"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
