<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.SwitchAccountPage"
             Title="Switch Account"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="#9E9E9E" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="16,20,16,8" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="0.5" />
            <Setter Property="Color" Value="#E0E0E0" />
            <Setter Property="Margin" Value="16,0,0,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,40">

            <Label Text="Signed In As" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Current account -->
            <Grid Padding="16,0" HeightRequest="72">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                        BackgroundColor="#FC5200" StrokeThickness="0" VerticalOptions="Center" Margin="0,0,12,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                    <Label Text="J" TextColor="White" FontSize="20" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="John Dela Cruz" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="john@email.com" FontSize="13" TextColor="#9E9E9E" />
                </VerticalStackLayout>
                <Label Grid.Column="2" Text="◉" FontSize="22" TextColor="#FC5200" VerticalOptions="Center" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Other accounts -->
            <Label Text="Other Accounts" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Padding="16,0" HeightRequest="72">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSwitchAccount" CommandParameter="jane@email.com" />
                </Grid.GestureRecognizers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                        BackgroundColor="#2196F3" StrokeThickness="0" VerticalOptions="Center" Margin="0,0,12,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                    <Label Text="J" TextColor="White" FontSize="20" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="Jane Dela Cruz" FontSize="16"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="jane@email.com" FontSize="13" TextColor="#9E9E9E" />
                </VerticalStackLayout>
                <Label Grid.Column="2" Text="○" FontSize="22" TextColor="#BDBDBD" VerticalOptions="Center" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Add Account -->
            <Button Text="+ Add Account"
                    Clicked="OnAddAccount"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="12"
                    HeightRequest="48"
                    Margin="16,24,16,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
