<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.DownloadMyDataPage"
             Title="Download My Data"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="24,40,24,40" Spacing="20">

            <Label Text="📦" FontSize="72" HorizontalOptions="Center" />

            <Label Text="Export a copy of all your data including activities, routes, and profile info."
                   FontSize="16"
                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <!-- What's included -->
            <Border StrokeThickness="0" Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Border.BackgroundColor>
                    <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                </Border.BackgroundColor>
                <VerticalStackLayout Spacing="8">
                    <Label Text="What's included:" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="• Activity history" FontSize="14" TextColor="#9E9E9E" />
                    <Label Text="• GPS routes" FontSize="14" TextColor="#9E9E9E" />
                    <Label Text="• Profile information" FontSize="14" TextColor="#9E9E9E" />
                    <Label Text="• Personal records" FontSize="14" TextColor="#9E9E9E" />
                </VerticalStackLayout>
            </Border>

            <!-- Format Selector -->
            <Border StrokeThickness="0" Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Border.BackgroundColor>
                    <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                </Border.BackgroundColor>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Format" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" x:Name="JsonBorder"
                                StrokeThickness="2" Stroke="#FC5200" Padding="0" HeightRequest="44">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFormatSelected" CommandParameter="JSON" />
                            </Border.GestureRecognizers>
                            <Label Text="JSON" FontSize="15" FontAttributes="Bold" TextColor="#FC5200" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Border Grid.Column="1" x:Name="CsvBorder"
                                StrokeThickness="2" Padding="0" HeightRequest="44">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.Stroke>
                                <AppThemeBinding Light="#E0E0E0" Dark="#444444"/>
                            </Border.Stroke>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFormatSelected" CommandParameter="CSV" />
                            </Border.GestureRecognizers>
                            <Label Text="CSV" FontSize="15" FontAttributes="Bold" TextColor="#9E9E9E" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Request Button -->
            <Button Text="Request Export"
                    Clicked="OnRequestExport"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    Margin="0,8,0,0" />

            <Label Text="You'll receive an email when your export is ready."
                   FontSize="13"
                   TextColor="#9E9E9E"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
