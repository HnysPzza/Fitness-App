<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.UnitsSelectionPage"
             Title="Units"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="#9E9E9E" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="16,20,16,8" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="RowGridStyle" TargetType="Grid">
            <Setter Property="HeightRequest" Value="56" />
            <Setter Property="Padding" Value="16,0" />
        </Style>
        <Style x:Key="RowLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="0.5" />
            <Setter Property="Color" Value="#E0E0E0" />
            <Setter Property="Margin" Value="16,0,0,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,40">

            <!-- Distance -->
            <Label Text="Distance" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />
            <Grid Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDistanceSelected" CommandParameter="Kilometers (km)" />
                </Grid.GestureRecognizers>
                <Label Text="Kilometers (km)" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="KmCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
                <Label x:Name="KmUncheck" Text="○" FontSize="20" TextColor="#BDBDBD" HorizontalOptions="End" VerticalOptions="Center" IsVisible="False" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />
            <Grid Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDistanceSelected" CommandParameter="Miles (mi)" />
                </Grid.GestureRecognizers>
                <Label Text="Miles (mi)" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="MiCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="End" VerticalOptions="Center" IsVisible="False" />
                <Label x:Name="MiUncheck" Text="○" FontSize="20" TextColor="#BDBDBD" HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Weight -->
            <Label Text="Weight" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />
            <Grid Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWeightSelected" CommandParameter="Kilograms (kg)" />
                </Grid.GestureRecognizers>
                <Label Text="Kilograms (kg)" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="KgCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
                <Label x:Name="KgUncheck" Text="○" FontSize="20" TextColor="#BDBDBD" HorizontalOptions="End" VerticalOptions="Center" IsVisible="False" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />
            <Grid Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWeightSelected" CommandParameter="Pounds (lbs)" />
                </Grid.GestureRecognizers>
                <Label Text="Pounds (lbs)" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="LbsCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="End" VerticalOptions="Center" IsVisible="False" />
                <Label x:Name="LbsUncheck" Text="○" FontSize="20" TextColor="#BDBDBD" HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Elevation -->
            <Label Text="Elevation" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />
            <Grid Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnElevationSelected" CommandParameter="Meters (m)" />
                </Grid.GestureRecognizers>
                <Label Text="Meters (m)" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="MCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
                <Label x:Name="MUncheck" Text="○" FontSize="20" TextColor="#BDBDBD" HorizontalOptions="End" VerticalOptions="Center" IsVisible="False" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />
            <Grid Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnElevationSelected" CommandParameter="Feet (ft)" />
                </Grid.GestureRecognizers>
                <Label Text="Feet (ft)" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="FtCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="End" VerticalOptions="Center" IsVisible="False" />
                <Label x:Name="FtUncheck" Text="○" FontSize="20" TextColor="#BDBDBD" HorizontalOptions="End" VerticalOptions="Center" IsVisible="True" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
