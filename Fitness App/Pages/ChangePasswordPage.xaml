<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.ChangePasswordPage"
             Title="Change Password"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="16,20,16,40" Spacing="16">

            <!-- Current Password -->
            <Label Text="Current Password" FontSize="13" TextColor="#9E9E9E" FontAttributes="Bold" />
            <Border StrokeThickness="1" Padding="12,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Border.Stroke>
                    <AppThemeBinding Light="#E0E0E0" Dark="#333333"/>
                </Border.Stroke>
                <Border.BackgroundColor>
                    <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                </Border.BackgroundColor>
                <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                    <Entry Grid.Column="0"
                           x:Name="CurrentPasswordEntry"
                           IsPassword="True"
                           Placeholder="Enter current password"
                           PlaceholderColor="#9E9E9E"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"
                           TextChanged="OnPasswordTextChanged" />
                    <Button Grid.Column="1"
                            x:Name="ShowCurrentBtn"
                            Text="👁"
                            BackgroundColor="Transparent"
                            TextColor="#9E9E9E"
                            FontSize="18"
                            Padding="0"
                            WidthRequest="40"
                            Clicked="OnToggleCurrentPassword" />
                </Grid>
            </Border>

            <!-- New Password -->
            <Label Text="New Password" FontSize="13" TextColor="#9E9E9E" FontAttributes="Bold" />
            <Border StrokeThickness="1" Padding="12,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Border.Stroke>
                    <AppThemeBinding Light="#E0E0E0" Dark="#333333"/>
                </Border.Stroke>
                <Border.BackgroundColor>
                    <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                </Border.BackgroundColor>
                <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                    <Entry Grid.Column="0"
                           x:Name="NewPasswordEntry"
                           IsPassword="True"
                           Placeholder="Enter new password"
                           PlaceholderColor="#9E9E9E"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"
                           TextChanged="OnPasswordTextChanged" />
                    <Button Grid.Column="1"
                            x:Name="ShowNewBtn"
                            Text="👁"
                            BackgroundColor="Transparent"
                            TextColor="#9E9E9E"
                            FontSize="18"
                            Padding="0"
                            WidthRequest="40"
                            Clicked="OnToggleNewPassword" />
                </Grid>
            </Border>

            <!-- Confirm New Password -->
            <Label Text="Confirm New Password" FontSize="13" TextColor="#9E9E9E" FontAttributes="Bold" />
            <Border StrokeThickness="1" Padding="12,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Border.Stroke>
                    <AppThemeBinding Light="#E0E0E0" Dark="#333333"/>
                </Border.Stroke>
                <Border.BackgroundColor>
                    <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                </Border.BackgroundColor>
                <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                    <Entry Grid.Column="0"
                           x:Name="ConfirmPasswordEntry"
                           IsPassword="True"
                           Placeholder="Confirm new password"
                           PlaceholderColor="#9E9E9E"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"
                           TextChanged="OnPasswordTextChanged" />
                    <Button Grid.Column="1"
                            x:Name="ShowConfirmBtn"
                            Text="👁"
                            BackgroundColor="Transparent"
                            TextColor="#9E9E9E"
                            FontSize="18"
                            Padding="0"
                            WidthRequest="40"
                            Clicked="OnToggleConfirmPassword" />
                </Grid>
            </Border>

            <!-- Validation Checklist -->
            <Border StrokeThickness="0" Padding="16,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Border.BackgroundColor>
                    <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                </Border.BackgroundColor>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="Check8Chars" Grid.Column="0" Text="○" FontSize="16" TextColor="#BDBDBD" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="8+ characters" FontSize="14" TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="CheckUppercase" Grid.Column="0" Text="○" FontSize="16" TextColor="#BDBDBD" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="One uppercase letter" FontSize="14" TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="CheckNumber" Grid.Column="0" Text="○" FontSize="16" TextColor="#BDBDBD" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="One number" FontSize="14" TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="CheckSpecial" Grid.Column="0" Text="○" FontSize="16" TextColor="#BDBDBD" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="One special character" FontSize="14" TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Update Button -->
            <Button x:Name="UpdateButton"
                    Text="Update Password"
                    Clicked="OnUpdatePasswordClicked"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    IsEnabled="False"
                    Opacity="0.5"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
