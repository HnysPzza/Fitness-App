<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.ChangePasswordPage"
             Title="Change Password"
             BackgroundColor="#0B0F19">

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Change Password"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Update your sign-in credentials and make sure your account stays protected."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="14">

            <!-- Current Password -->
            <Label Text="Current Password" FontSize="12" TextColor="#64748B" FontAttributes="Bold" />
            <Border Stroke="#243041" StrokeThickness="1" Padding="14,0" BackgroundColor="#0F172A">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                    <Entry Grid.Column="0"
                           x:Name="CurrentPasswordEntry"
                           IsPassword="True"
                           Placeholder="Enter current password"
                           PlaceholderColor="#64748B"
                           TextColor="#F8FAFC"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"
                           TextChanged="OnPasswordTextChanged" />
                    <Button Grid.Column="1"
                            x:Name="ShowCurrentBtn"
                            Text="👁"
                            BackgroundColor="Transparent"
                            TextColor="#94A3B8"
                            FontSize="18"
                            Padding="0"
                            WidthRequest="40"
                            Clicked="OnToggleCurrentPassword" />
                </Grid>
            </Border>

            <!-- New Password -->
            <Label Text="New Password" FontSize="12" TextColor="#64748B" FontAttributes="Bold" />
            <Border Stroke="#243041" StrokeThickness="1" Padding="14,0" BackgroundColor="#0F172A">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                    <Entry Grid.Column="0"
                           x:Name="NewPasswordEntry"
                           IsPassword="True"
                           Placeholder="Enter new password"
                           PlaceholderColor="#64748B"
                           TextColor="#F8FAFC"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"
                           TextChanged="OnPasswordTextChanged" />
                    <Button Grid.Column="1"
                            x:Name="ShowNewBtn"
                            Text="👁"
                            BackgroundColor="Transparent"
                            TextColor="#94A3B8"
                            FontSize="18"
                            Padding="0"
                            WidthRequest="40"
                            Clicked="OnToggleNewPassword" />
                </Grid>
            </Border>

            <!-- Confirm New Password -->
            <Label Text="Confirm New Password" FontSize="12" TextColor="#64748B" FontAttributes="Bold" />
            <Border Stroke="#243041" StrokeThickness="1" Padding="14,0" BackgroundColor="#0F172A">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                    <Entry Grid.Column="0"
                           x:Name="ConfirmPasswordEntry"
                           IsPassword="True"
                           Placeholder="Confirm new password"
                           PlaceholderColor="#64748B"
                           TextColor="#F8FAFC"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"
                           TextChanged="OnPasswordTextChanged" />
                    <Button Grid.Column="1"
                            x:Name="ShowConfirmBtn"
                            Text="👁"
                            BackgroundColor="Transparent"
                            TextColor="#94A3B8"
                            FontSize="18"
                            Padding="0"
                            WidthRequest="40"
                            Clicked="OnToggleConfirmPassword" />
                </Grid>
            </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Validation Checklist -->
            <Border Stroke="#243041" StrokeThickness="1" Padding="18" BackgroundColor="#111827">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Password requirements"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="Check8Chars" Grid.Column="0" Text="○" FontSize="16" TextColor="#475569" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="8+ characters" FontSize="14" TextColor="#CBD5E1" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="CheckUppercase" Grid.Column="0" Text="○" FontSize="16" TextColor="#475569" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="One uppercase letter" FontSize="14" TextColor="#CBD5E1" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="CheckNumber" Grid.Column="0" Text="○" FontSize="16" TextColor="#475569" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="One number" FontSize="14" TextColor="#CBD5E1" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label x:Name="CheckSpecial" Grid.Column="0" Text="○" FontSize="16" TextColor="#475569" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="One special character" FontSize="14" TextColor="#CBD5E1" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Update Button -->
            <Button x:Name="UpdateButton"
                    Text="Update Password"
                    Clicked="OnUpdatePasswordClicked"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="16"
                    HeightRequest="52"
                    IsEnabled="False"
                    Opacity="0.5"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
