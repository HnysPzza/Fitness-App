<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.TermsOfServicePage"
             Title="Terms of Service"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,40" Spacing="16">

            <Label Text="Last updated: January 1, 2025"
                   FontSize="13"
                   TextColor="#9E9E9E" />

            <Label Text="Terms of Service"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

            <Label TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" FontSize="15" LineBreakMode="WordWrap">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="1. Acceptance of Terms&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="By downloading, installing, or using the Fitness App (the 'Service'), you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use the Service.&#10;&#10;" />
                        <Span Text="2. Use of the Service&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="The Fitness App is provided for your personal, non-commercial use. You agree not to reproduce, duplicate, copy, sell, or exploit any portion of the Service without express written permission from us.&#10;&#10;" />
                        <Span Text="3. User Accounts&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="You are responsible for maintaining the confidentiality of your account credentials and for all activities that occur under your account. You agree to notify us immediately of any unauthorized use.&#10;&#10;" />
                        <Span Text="4. Health Disclaimer&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="The Fitness App is not a medical device and is not intended to diagnose, treat, cure, or prevent any medical condition. Always consult a qualified healthcare provider before starting any exercise program.&#10;&#10;" />
                        <Span Text="5. Privacy&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="Your privacy is important to us. Please review our Privacy Policy to understand how we collect, use, and protect your personal data.&#10;&#10;" />
                        <Span Text="6. Intellectual Property&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="All content, features, and functionality of the Fitness App are owned by us and are protected by international copyright, trademark, and other intellectual property laws.&#10;&#10;" />
                        <Span Text="7. Limitation of Liability&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="To the maximum extent permitted by law, we shall not be liable for any indirect, incidental, special, or consequential damages arising out of your use of the Service.&#10;&#10;" />
                        <Span Text="8. Changes to Terms&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="We reserve the right to modify these Terms at any time. We will notify you of significant changes. Your continued use of the Service after changes constitutes acceptance of the new Terms.&#10;&#10;" />
                        <Span Text="9. Contact Us&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="If you have any questions about these Terms of Service, please contact us at support@fitnessapp.com." />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <BoxView HeightRequest="0.5" Color="#E0E0E0" Margin="0,8,0,8" />

            <Button Text="Open in Browser"
                    Clicked="OnOpenInBrowser"
                    BackgroundColor="Transparent"
                    TextColor="#FC5200"
                    BorderColor="#FC5200"
                    BorderWidth="1.5"
                    CornerRadius="10"
                    FontSize="15"
                    HeightRequest="44" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
