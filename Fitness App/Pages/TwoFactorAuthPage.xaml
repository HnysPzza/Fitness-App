<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.TwoFactorAuthPage"
             Title="Two-Factor Authentication"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="24,40,24,40" Spacing="20">

            <!-- Disabled State -->
            <VerticalStackLayout x:Name="DisabledView" Spacing="20">
                <Label Text="🔒"
                       FontSize="72"
                       HorizontalOptions="Center" />

                <Label Text="Add an extra layer of security to your account."
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <Label Text="When enabled, you'll need your password + a verification code each time you sign in."
                       FontSize="15"
                       TextColor="#9E9E9E"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />

                <Button Text="Enable 2FA"
                        Clicked="OnEnable2FA"
                        BackgroundColor="#FC5200"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        Margin="0,16,0,0" />
            </VerticalStackLayout>

            <!-- Enabled State -->
            <VerticalStackLayout x:Name="EnabledView" Spacing="16" IsVisible="False">
                <Label Text="✅"
                       FontSize="72"
                       HorizontalOptions="Center" />

                <Label Text="Two-Factor Authentication is Active"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <Label Text="Your account is protected with an extra layer of security."
                       FontSize="14"
                       TextColor="#9E9E9E"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <Border StrokeThickness="0" Padding="16,12" Margin="0,8,0,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.BackgroundColor>
                        <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                    </Border.BackgroundColor>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="📱" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Authenticator App" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                            <Label Text="Active method" FontSize="13" TextColor="#4CAF50" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Button Text="View Recovery Codes"
                        Clicked="OnViewRecoveryCodes"
                        BackgroundColor="Transparent"
                        TextColor="#FC5200"
                        BorderColor="#FC5200"
                        BorderWidth="1.5"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="12"
                        HeightRequest="48" />

                <Button Text="Disable 2FA"
                        Clicked="OnDisable2FA"
                        BackgroundColor="#E53935"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="12"
                        HeightRequest="48"
                        Margin="0,8,0,0" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
