<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.TwoFactorAuthPage"
             Title="Two-Factor Authentication"
             BackgroundColor="#0B0F19">

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Two-Factor Authentication"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Protect your account with an additional verification step whenever you sign in."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <!-- Disabled State -->
            <Border x:Name="DisabledView"
                    Padding="22"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="18">
                    <Label Text="🔒"
                           FontSize="68"
                           HorizontalOptions="Center" />

                    <Label Text="Add an extra layer of security to your account."
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Label Text="When enabled, you'll need your password plus a verification code each time you sign in."
                           FontSize="14"
                           TextColor="#94A3B8"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                    <Border Padding="16"
                            BackgroundColor="#0F172A"
                            Stroke="#243041"
                            StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="What you get"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#F8FAFC" />
                            <Label Text="Verification code during sign-in"
                                   FontSize="13"
                                   TextColor="#CBD5E1" />
                            <Label Text="Extra protection for password leaks"
                                   FontSize="13"
                                   TextColor="#CBD5E1" />
                            <Label Text="Recovery-code fallback support"
                                   FontSize="13"
                                   TextColor="#CBD5E1" />
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="Enable 2FA"
                            Clicked="OnEnable2FA"
                            BackgroundColor="#FC5200"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="16"
                            HeightRequest="52"
                            Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Enabled State -->
            <Border x:Name="EnabledView"
                    Padding="22"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1"
                    IsVisible="False">
                <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Label Text="✅"
                           FontSize="68"
                           HorizontalOptions="Center" />

                    <Label Text="Two-Factor Authentication is Active"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Your account is protected with an extra layer of security."
                           FontSize="14"
                           TextColor="#94A3B8"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Border Stroke="#243041" StrokeThickness="1" Padding="16" Margin="0,4,0,0" BackgroundColor="#0F172A">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Grid.Column="0" Text="📱" FontSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Authenticator App" FontSize="16" FontAttributes="Bold" TextColor="#F8FAFC" />
                                <Label Text="Active method" FontSize="13" TextColor="#22C55E" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Button Text="View Recovery Codes"
                            Clicked="OnViewRecoveryCodes"
                            BackgroundColor="Transparent"
                            TextColor="#FC5200"
                            BorderColor="#FC5200"
                            BorderWidth="1.5"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="16"
                            HeightRequest="48" />

                    <Button Text="Disable 2FA"
                            Clicked="OnDisable2FA"
                            BackgroundColor="#E53935"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="16"
                            HeightRequest="48"
                            Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
