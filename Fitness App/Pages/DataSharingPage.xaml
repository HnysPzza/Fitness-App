<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.DataSharingPage"
             Title="Data Sharing"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="0.5" />
            <Setter Property="Color" Value="#E0E0E0" />
            <Setter Property="Margin" Value="16,0,0,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,40">

            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Analytics Toggle -->
            <Grid Padding="16,0" MinimumHeightRequest="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4" Margin="0,12,16,12">
                    <Label Text="Analytics &amp; Improvement" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="Share anonymous usage data to help improve the app" FontSize="13" TextColor="#9E9E9E" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
                <Switch Grid.Column="1"
                        x:Name="AnalyticsSwitch"
                        OnColor="#FC5200"
                        VerticalOptions="Center"
                        Toggled="OnAnalyticsToggled" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Activity Visibility -->
            <Grid Padding="16,0" HeightRequest="64">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnActivityVisibilityTapped" />
                </Grid.GestureRecognizers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                    <Label Text="Activity Visibility" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="Who can see your activities" FontSize="13" TextColor="#9E9E9E" />
                </VerticalStackLayout>
                <StackLayout Grid.Column="1" Orientation="Horizontal" VerticalOptions="Center" Spacing="4">
                    <Label x:Name="ActivityVisibilityLabel" Text="Everyone" FontSize="15" TextColor="#9E9E9E" VerticalOptions="Center" />
                    <Label Text="›" FontSize="22" TextColor="#BDBDBD" VerticalOptions="Center" />
                </StackLayout>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Profile Visibility -->
            <Grid Padding="16,0" HeightRequest="64">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileVisibilityTapped" />
                </Grid.GestureRecognizers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                    <Label Text="Profile Visibility" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="Who can find your profile" FontSize="13" TextColor="#9E9E9E" />
                </VerticalStackLayout>
                <StackLayout Grid.Column="1" Orientation="Horizontal" VerticalOptions="Center" Spacing="4">
                    <Label x:Name="ProfileVisibilityLabel" Text="Friends Only" FontSize="15" TextColor="#9E9E9E" VerticalOptions="Center" />
                    <Label Text="›" FontSize="22" TextColor="#BDBDBD" VerticalOptions="Center" />
                </StackLayout>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Location Sharing Toggle -->
            <Grid Padding="16,0" MinimumHeightRequest="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4" Margin="0,12,16,12">
                    <Label Text="Location Sharing" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="Share live location during activities" FontSize="13" TextColor="#9E9E9E" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
                <Switch Grid.Column="1"
                        x:Name="LocationSwitch"
                        OnColor="#FC5200"
                        VerticalOptions="Center"
                        Toggled="OnLocationToggled" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
