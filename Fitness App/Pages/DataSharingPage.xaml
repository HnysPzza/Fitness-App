<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.DataSharingPage"
             Title="Data Sharing"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Data Sharing"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Control what profile, location, and analytics data can be shared from your account."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <!-- Analytics Toggle -->
            <Grid Padding="18,14" MinimumHeightRequest="72">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4" Margin="0,12,16,12">
                    <Label Text="Analytics &amp; Improvement" FontSize="16" FontAttributes="Bold" TextColor="#F8FAFC" />
                    <Label Text="Share anonymous usage data to help improve the app" FontSize="13" TextColor="#94A3B8" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
                <Switch Grid.Column="1"
                        x:Name="AnalyticsSwitch"
                        OnColor="#FC5200"
                        VerticalOptions="Center"
                        Toggled="OnAnalyticsToggled" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Activity Visibility -->
            <Grid Padding="18,14" MinimumHeightRequest="72">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnActivityVisibilityTapped" />
                </Grid.GestureRecognizers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                    <Label Text="Activity Visibility" FontSize="16" FontAttributes="Bold" TextColor="#F8FAFC" />
                    <Label Text="Who can see your activities" FontSize="13" TextColor="#94A3B8" />
                </VerticalStackLayout>
                <StackLayout Grid.Column="1" Orientation="Horizontal" VerticalOptions="Center" Spacing="4">
                    <Label x:Name="ActivityVisibilityLabel" Text="Everyone" FontSize="15" TextColor="#F8FAFC" VerticalOptions="Center" />
                    <Label Text="›" FontSize="22" TextColor="#64748B" VerticalOptions="Center" />
                </StackLayout>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Profile Visibility -->
            <Grid Padding="18,14" MinimumHeightRequest="72">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileVisibilityTapped" />
                </Grid.GestureRecognizers>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                    <Label Text="Profile Visibility" FontSize="16" FontAttributes="Bold" TextColor="#F8FAFC" />
                    <Label Text="Who can find your profile" FontSize="13" TextColor="#94A3B8" />
                </VerticalStackLayout>
                <StackLayout Grid.Column="1" Orientation="Horizontal" VerticalOptions="Center" Spacing="4">
                    <Label x:Name="ProfileVisibilityLabel" Text="Friends Only" FontSize="15" TextColor="#F8FAFC" VerticalOptions="Center" />
                    <Label Text="›" FontSize="22" TextColor="#64748B" VerticalOptions="Center" />
                </StackLayout>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Location Sharing Toggle -->
            <Grid Padding="18,14" MinimumHeightRequest="72">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4" Margin="0,12,16,12">
                    <Label Text="Location Sharing" FontSize="16" FontAttributes="Bold" TextColor="#F8FAFC" />
                    <Label Text="Share live location during activities" FontSize="13" TextColor="#94A3B8" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
                <Switch Grid.Column="1"
                        x:Name="LocationSwitch"
                        OnColor="#FC5200"
                        VerticalOptions="Center"
                        Toggled="OnLocationToggled" />
            </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
