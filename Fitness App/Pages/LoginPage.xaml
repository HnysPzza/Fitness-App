<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:vm="clr-namespace:Fitness_App.ViewModels"
             x:Class="Fitness_App.Pages.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0B0F19}">

    <ScrollView>
        <Grid Padding="28,0" RowSpacing="0"
              VerticalOptions="Center"
              MinimumHeightRequest="700">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════════
                 LOGO AREA
                 ═══════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="8"
                                 HorizontalOptions="Center"
                                 Margin="0,60,0,36">

                <!-- App Icon Circle -->
                <Border HeightRequest="80"
                        WidthRequest="80"
                        StrokeThickness="0"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FC5200" Offset="0" />
                            <GradientStop Color="#FF6B35" Offset="0.5" />
                            <GradientStop Color="#FF8C42" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#FC5200" Radius="30" Opacity="0.35" Offset="0,8" />
                    </Border.Shadow>
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Directions_run}"
                                       FontSize="40"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                </Border>

                <Label Text="StrideX"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
            </VerticalStackLayout>

            <!-- ═══════════════════════════════════════════════════════════════
                 WELCOME TEXT
                 ═══════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="6"
                                 Margin="0,0,0,28">
                <Label Text="Welcome back 👋"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                <Label Text="Sign in to continue tracking your fitness journey"
                       FontSize="14"
                       Opacity="0.65"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />
            </VerticalStackLayout>

            <!-- ═══════════════════════════════════════════════════════════════
                 EMAIL INPUT
                 ═══════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Grid.Row="2" Spacing="6" Margin="0,0,0,16">
                <Label Text="Email"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />

                <Border StrokeThickness="1.5"
                        Padding="14,0"
                        HeightRequest="52"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Email}"
                                           FontSize="20"
                                           Opacity="0.5"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        <Entry Grid.Column="1"
                               x:Name="EmailEntry"
                               Placeholder="you@example.com"
                               Keyboard="Email"
                               ReturnType="Next"
                               Text="{Binding Email}"
                               FontSize="15"
                               VerticalOptions="Center"
                               PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#475569}"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    </Grid>
                </Border>

                <!-- Email Error -->
                <Label Text="{Binding EmailError}"
                       IsVisible="{Binding EmailError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12"
                       TextColor="#EF4444"
                       Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- ═══════════════════════════════════════════════════════════════
                 PASSWORD INPUT
                 ═══════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Grid.Row="3" Spacing="6" Margin="0,0,0,12">
                <Label Text="Password"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />

                <Border StrokeThickness="1.5"
                        Padding="14,0"
                        HeightRequest="52"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Lock}"
                                           FontSize="20"
                                           Opacity="0.5"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        <Entry Grid.Column="1"
                               x:Name="PasswordEntry"
                               Placeholder="Enter your password"
                               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                               ReturnType="Go"
                               Text="{Binding Password}"
                               FontSize="15"
                               VerticalOptions="Center"
                               PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#475569}"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />

                        <!-- Show / Hide toggle -->
                        <controls:IconLabel Grid.Column="2"
                                           Text="{x:Static icons:MaterialSymbols.Visibility}"
                                           FontSize="20"
                                           Opacity="0.5"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}">
                            <controls:IconLabel.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                            </controls:IconLabel.GestureRecognizers>
                        </controls:IconLabel>
                    </Grid>
                </Border>

                <!-- Password Error -->
                <Label Text="{Binding PasswordError}"
                       IsVisible="{Binding PasswordError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                       FontSize="12"
                       TextColor="#EF4444"
                       Margin="4,0,0,0" />
            </VerticalStackLayout>

            <!-- ═══════════════════════════════════════════════════════════════
                 GENERAL ERROR
                 ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    IsVisible="{Binding GeneralError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                    StrokeThickness="0"
                    BackgroundColor="#1AEF4444"
                    Padding="14,10"
                    Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="10">
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Warning}"
                                       FontSize="18"
                                       TextColor="#EF4444"
                                       VerticalOptions="Center" />
                    <Label Text="{Binding GeneralError}"
                           FontSize="13"
                           TextColor="#EF4444"
                           VerticalOptions="Center"
                           LineBreakMode="WordWrap"
                           HorizontalOptions="FillAndExpand" />
                </HorizontalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 LOGIN BUTTON
                 ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="5" Margin="0,4,0,24">
                <Button Text="Sign In"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="White"
                        HeightRequest="56"
                        CornerRadius="16"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FC5200" Offset="0" />
                            <GradientStop Color="#FF6B35" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Shadow>
                        <Shadow Brush="#FC5200" Radius="25" Opacity="0.4" Offset="0,8" />
                    </Button.Shadow>
                </Button>

                <!-- Loading overlay -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="White"
                                   HeightRequest="28"
                                   WidthRequest="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════
                 DIVIDER
                 ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="6"
                  ColumnDefinitions="*,Auto,*"
                  Margin="0,0,0,24">
                <BoxView HeightRequest="1"
                         VerticalOptions="Center"
                         Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />
                <Label Grid.Column="1"
                       Text="  or  "
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}" />
                <BoxView Grid.Column="2"
                         HeightRequest="1"
                         VerticalOptions="Center"
                         Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════
                 GOOGLE SIGN-IN BUTTON
                 ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="7"
                    StrokeThickness="1.5"
                    HeightRequest="56"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                    Margin="0,0,0,32">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoogleSignInTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Spacing="12">
                    <Label Text="G"
                           FontSize="22"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="#4285F4" />
                    <Label Text="Continue with Google"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                </HorizontalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 FOOTER
                 ═══════════════════════════════════════════════════════════ -->
            <HorizontalStackLayout Grid.Row="8"
                                   HorizontalOptions="Center"
                                   Spacing="4"
                                   Margin="0,0,0,40">
                <Label Text="Don't have an account?"
                       FontSize="13"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}" />
                <Label Text="Sign up"
                       FontSize="13"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="#FC5200">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignUpTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
