<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.HelpFaqPage"
             Title="Help &amp; FAQ"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <VerticalStackLayout Spacing="0">

        <!-- Search Bar -->
        <Border StrokeThickness="0" Margin="16,12,16,4" Padding="12,8">
            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
            <Border.BackgroundColor>
                <AppThemeBinding Light="#EBEBEB" Dark="#2C2C2E"/>
            </Border.BackgroundColor>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Label Grid.Column="0" Text="🔍" FontSize="16" VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       Placeholder="Search help articles..."
                       PlaceholderColor="#9E9E9E"
                       TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                       BackgroundColor="Transparent"
                       TextChanged="OnSearchChanged" />
            </Grid>
        </Border>

        <ScrollView>
            <VerticalStackLayout x:Name="FaqContainer" Padding="0,8,0,40" />
        </ScrollView>

    </VerticalStackLayout>
</ContentPage>
