<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.HelpFaqPage"
             Title="Help &amp; FAQ"
             BackgroundColor="#0B0F19">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16,18,16,40">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Help &amp; FAQ"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Search common questions about recording, maps, notifications, accounts, and connected devices."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#243041" StrokeThickness="1" Padding="14,10" BackgroundColor="#111827">
                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="🔍" FontSize="16" VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           Placeholder="Search help articles..."
                           PlaceholderColor="#64748B"
                           TextColor="#F8FAFC"
                           BackgroundColor="Transparent"
                           TextChanged="OnSearchChanged" />
                </Grid>
            </Border>

            <VerticalStackLayout x:Name="FaqContainer" Padding="0,0,0,8" Spacing="12" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
