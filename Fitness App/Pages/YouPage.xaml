<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="Fitness_App.Pages.YouPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F6F8FB, Dark=#0B0F19}">

    <ScrollView BackgroundColor="{AppThemeBinding Light=#F6F8FB, Dark=#0B0F19}">
        <VerticalStackLayout Spacing="24" Padding="20,20,20,88">

            <!-- Top Nav Bar -->
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                <!-- Left: Profile & Logo -->
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Border HeightRequest="40"
                            WidthRequest="40"
                            StrokeThickness="2"
                            Stroke="#FC5200">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Grid>
                            <Border x:Name="ProfileIconContainer"
                                    BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#1B263B}"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <controls:IconLabel x:Name="ProfileIcon"
                                                   Text="{x:Static icons:MaterialSymbols.Person}"
                                                   FontSize="24"
                                                   TextColor="#FC5200"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                            </Border>
                            <Image x:Name="ProfileImage"
                                   IsVisible="False"
                                   Aspect="AspectFill"
                                   WidthRequest="36"
                                   HeightRequest="36"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Image.Clip>
                                    <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18" />
                                </Image.Clip>
                            </Image>
                        </Grid>
                    </Border>
                    
                    <Label Text="STRIDEX"
                           FontFamily="OpenSansBold"
                           FontSize="18"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Right: Action Icons -->
                <HorizontalStackLayout Grid.Column="2" Spacing="12" VerticalOptions="Center">
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Settings}"
                                       FontSize="28"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}">
                        <controls:IconLabel.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsClicked" />
                        </controls:IconLabel.GestureRecognizers>
                    </controls:IconLabel>
                </HorizontalStackLayout>
            </Grid>

            <!-- User Headline -->
            <VerticalStackLayout Spacing="4">
                <Label x:Name="UserNameLabel"
                       Text="Alex Sterling"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
            </VerticalStackLayout>

            <!-- Your Progress Section -->
            <VerticalStackLayout Spacing="12">
                <!-- Section Title -->
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Your Progress" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Featured: Total KM Card -->
                <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid Padding="20,18" RowDefinitions="Auto,Auto,Auto">
                        <!-- Watermark Icon -->
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Location_on}"
                                           FontSize="110"
                                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                           Opacity="0.04"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           TranslationX="12"
                                           TranslationY="8"
                                           Grid.RowSpan="3"
                                           InputTransparent="True" />

                        <Label Text="TOTAL KILOMETERS"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />

                        <HorizontalStackLayout Grid.Row="1" Spacing="4" VerticalOptions="Center" Margin="0,6,0,0">
                            <Label x:Name="StatKmLabel"
                                   Text="1,284.5"
                                   FontSize="48"
                                   FontAttributes="Bold"
                                   TextColor="#FC5200" />
                            <Label Text="KM"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#FC5200"
                                   VerticalOptions="End"
                                   Margin="2,0,0,10" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Row="2" Spacing="5" Margin="0,6,0,0">
                            <controls:IconLabel x:Name="KmTrendIcon"
                                               Text="{x:Static icons:MaterialSymbols.Trending_up}"
                                               FontSize="14"
                                               TextColor="#FC5200" />
                            <Label x:Name="KmTrendLabel"
                                   Text="+12% from last month"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FC5200" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- 2x2 Stats Grid -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                    <!-- Total Activities -->
                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="18,16" Spacing="6">
                            <Label Text="TOTAL ACTIVITIES"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.2"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            <Label x:Name="StatActivitiesLabel"
                                   Text="156"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            <Label Text="Sessions recorded"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Avg. Pace -->
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="18,16" Spacing="6">
                            <Label Text="AVG. PACE"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.2"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            <Label x:Name="StatSpeedLabel"
                                   Text="4'52&quot;"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            <Label Text="Min / KM"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Calories Burnt -->
                    <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="18,16" Spacing="6">
                            <Label Text="CALORIES BURNT"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.2"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            <Label x:Name="StatTimeLabel"
                                   Text="42k"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            <Label Text="Kcal total"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Active Days -->
                    <Border Grid.Row="1" Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="18,16" Spacing="6">
                            <Label Text="ACTIVE DAYS"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.2"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            <Label x:Name="StatActiveDaysLabel"
                                   Text="0"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            <Label Text="This month"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </VerticalStackLayout>


            <!-- Performance Load Chart Card -->
            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Padding="20" Spacing="24">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Performance&#x0a;Load" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" LineHeight="1.2" />

                        <!-- Segmented Control without TODAY -->
                        <Border Grid.Column="1" StrokeThickness="0" Padding="4" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#0B0F19}" VerticalOptions="Start">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <HorizontalStackLayout Spacing="2">
                                <Border x:Name="TabWeek" BackgroundColor="#FC5200" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTabWeek" />
                                    </Border.GestureRecognizers>
                                    <Label x:Name="TabWeekLabel" Text="WEEK" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Padding="14,8" TextColor="#FFFFFF" />
                                </Border>
                                <Border x:Name="TabMonth" BackgroundColor="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTabMonth" />
                                    </Border.GestureRecognizers>
                                    <Label x:Name="TabMonthLabel" Text="MONTH" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Padding="14,8" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                </Border>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- SkiaSharp bar chart -->
                    <skia:SKCanvasView x:Name="ChartCanvas" HeightRequest="160" PaintSurface="OnChartPaint" />

                    <!-- X-axis labels row -->
                    <Grid x:Name="XLabelsGrid" Margin="0,0">
                        <!-- filled in code-behind but we handle drawing in canvas now for better alignment, 
                        keeping the grid to avoid missing x:Name exceptions -->
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Resting Heart Rate -->
            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Padding="20">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="RESTING HEART RATE" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        <controls:IconLabel Grid.Column="1" Text="{x:Static icons:MaterialSymbols.Favorite}" TextColor="#FC5200" FontSize="18" />
                    </Grid>
                    
                    <HorizontalStackLayout Spacing="6" Margin="0,8,0,16" VerticalOptions="End">
                        <Label Text="54" FontSize="42" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                        <Label Text="BPM" FontSize="16" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" VerticalOptions="End" Margin="0,0,0,8" />
                    </HorizontalStackLayout>

                    <Label Text="Your recovery is Optimal today. You're&#x0a;ready for high-intensity training." FontSize="14" TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" LineHeight="1.4" Margin="0,0,0,24" />

                    <!-- Static EKG Line using Path (Scalable later) -->
                    <Path Aspect="Uniform" 
                          Stroke="#FC5200" 
                          StrokeThickness="3" 
                          StrokeLineJoin="Round"
                          StrokeLineCap="Round"
                          HorizontalOptions="Fill" 
                          HeightRequest="40"
                          Data="M0,20 L30,20 L40,35 L50,0 L60,40 L70,20 L110,20 L120,30 L130,15 L140,20 L180,20" />
                </VerticalStackLayout>
            </Border>

            <!-- Recent Activities Section -->
            <VerticalStackLayout Spacing="16">
                <!-- Section Title -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <BoxView WidthRequest="4" HeightRequest="18" Color="#FC5200" VerticalOptions="Center" CornerRadius="2" />
                    <Label Grid.Column="1" Text="Recent Activities" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" VerticalOptions="Center" Margin="8,0,0,0" />
                    <Label Grid.Column="2" Text="VIEW ALL" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="#FC5200" VerticalOptions="Center" Margin="0,4,0,0" />
                </Grid>

                <Label x:Name="RecentActivitiesEmptyLabel" Text="Your saved workouts will appear here." IsVisible="False" FontSize="14" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />

                <!-- Activity Card 1 -->
                <Border x:Name="ActivityCard1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRecentActivityTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border x:Name="ActivityBadge1" HeightRequest="60" WidthRequest="60" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#1B263B}" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <controls:IconLabel x:Name="ActivityEmoji1" Text="{x:Static icons:MaterialSymbols.Directions_run}" FontSize="28" TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="ActivityTitle1" Text="Morning Tempo Run" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </Grid>
                            <Label x:Name="ActivityMeta1" Text="8.24 km • 42:15 • YESTERDAY" FontSize="12" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        </VerticalStackLayout>
                        <controls:IconLabel Grid.Column="2" Text="{x:Static icons:MaterialSymbols.Chevron_right}" FontSize="24" TextColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Activity Card 2 -->
                <Border x:Name="ActivityCard2" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRecentActivityTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border x:Name="ActivityBadge2" HeightRequest="60" WidthRequest="60" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#1B263B}" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <controls:IconLabel x:Name="ActivityEmoji2" Text="{x:Static icons:MaterialSymbols.Directions_walk}" FontSize="28" TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="ActivityTitle2" Text="Evening Walk" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </Grid>
                            <Label x:Name="ActivityMeta2" Text="3.1 km • 35:12 • 2 DAYS AGO" FontSize="12" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        </VerticalStackLayout>
                        <controls:IconLabel Grid.Column="2" Text="{x:Static icons:MaterialSymbols.Chevron_right}" FontSize="24" TextColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Activity Card 3 -->
                <Border x:Name="ActivityCard3" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRecentActivityTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="16" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border x:Name="ActivityBadge3" HeightRequest="60" WidthRequest="60" BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#1B263B}" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <controls:IconLabel x:Name="ActivityEmoji3" Text="{x:Static icons:MaterialSymbols.Pool}" FontSize="28" TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="ActivityTitle3" Text="Swim" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                            </Grid>
                            <Label x:Name="ActivityMeta3" Text="1.2 km • 42:30 • 3 DAYS AGO" FontSize="12" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                        </VerticalStackLayout>
                        <controls:IconLabel Grid.Column="2" Text="{x:Static icons:MaterialSymbols.Chevron_right}" FontSize="24" TextColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}" VerticalOptions="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- bottom padding -->
            <Grid HeightRequest="20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
