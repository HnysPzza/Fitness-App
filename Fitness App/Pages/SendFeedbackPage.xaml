<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.SendFeedbackPage"
             Title="Send Feedback"
             BackgroundColor="#0B0F19">

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Send Feedback"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Report issues, suggest improvements, or share general feedback with the product team."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="14">

            <!-- Feedback Type -->
            <Label Text="What type of feedback?" FontSize="12" TextColor="#64748B" FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0" x:Name="BugBorder"
                        StrokeThickness="2" Stroke="#FC5200" Padding="0" HeightRequest="48" BackgroundColor="#0F172A">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTypeSelected" CommandParameter="Bug" />
                    </Border.GestureRecognizers>
                    <Label Text="🐛  Bug" FontSize="15" FontAttributes="Bold" TextColor="#FC5200" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Column="1" x:Name="SuggestionBorder"
                        StrokeThickness="2" Padding="0" HeightRequest="48" Stroke="#243041" BackgroundColor="#0F172A">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTypeSelected" CommandParameter="Suggestion" />
                    </Border.GestureRecognizers>
                    <Label Text="💡  Suggestion" FontSize="15" FontAttributes="Bold" TextColor="#94A3B8" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0" x:Name="OtherBorder"
                        StrokeThickness="2" Padding="0" HeightRequest="48" Stroke="#243041" BackgroundColor="#0F172A">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTypeSelected" CommandParameter="Other" />
                    </Border.GestureRecognizers>
                    <Label Text="⭐  Other" FontSize="15" FontAttributes="Bold" TextColor="#94A3B8" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <BoxView Grid.Column="1" IsVisible="False" />
            </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Feedback Text -->
            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Your feedback" FontSize="12" TextColor="#64748B" FontAttributes="Bold" />
                    <Border Stroke="#243041" StrokeThickness="1" Padding="14,10" BackgroundColor="#0F172A">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Editor x:Name="FeedbackEditor"
                        Placeholder="Describe your feedback here..."
                        PlaceholderColor="#64748B"
                        TextColor="#F8FAFC"
                        BackgroundColor="Transparent"
                        MinimumHeightRequest="120"
                        MaxLength="500"
                        TextChanged="OnFeedbackTextChanged" />
            </Border>
                    <Label x:Name="CharCount" Text="0/500" FontSize="12" TextColor="#94A3B8" HorizontalOptions="End" />
                </VerticalStackLayout>
            </Border>

            <!-- Screenshot -->
            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Attach screenshot (optional)" FontSize="12" TextColor="#64748B" FontAttributes="Bold" />
                    <Border StrokeThickness="1.5" Padding="0" HeightRequest="56" Stroke="#243041" BackgroundColor="#0F172A">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAddImage" />
                </Border.GestureRecognizers>
                <Label Text="+ Add Image"
                       FontSize="15"
                       TextColor="#FC5200"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Send Button -->
            <Button Text="Send Feedback"
                    Clicked="OnSendFeedback"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="16"
                    HeightRequest="52"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
