<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             x:Class="Fitness_App.Pages.ActivityDetailPage"
             Title="Activity Detail"
             BackgroundColor="#0F172A"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" Padding="18,48,18,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Border BackgroundColor="#FC5200" StrokeThickness="0" WidthRequest="48" HeightRequest="48">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
                <controls:IconLabel Text="{x:Static icons:MaterialSymbols.ArrowBack}"
                                    FontSize="22"
                                    TextColor="White"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                <Label x:Name="TitleLabel"
                       Text="Activity"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="White" />
                <Label x:Name="DateLabel"
                       Text=""
                       FontSize="12"
                       HorizontalOptions="Center"
                       TextColor="#94A3B8" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,0,18,28" Spacing="18">
                <Border BackgroundColor="#111827" Stroke="#1F2937" StrokeThickness="1" Padding="0" HeightRequest="320">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Grid>
                        <WebView x:Name="MapWebView" BackgroundColor="#0F1923" />
                        <Grid x:Name="MapLoadingOverlay" BackgroundColor="#0F1923" IsVisible="True">
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                                <ActivityIndicator IsRunning="True" Color="#FC5200" />
                                <Label Text="Loading route…" TextColor="#94A3B8" FontSize="13" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                    <Border Grid.Column="0" BackgroundColor="#111827" Stroke="#1F2937" StrokeThickness="1" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Distance" FontSize="12" TextColor="#94A3B8" />
                            <Label x:Name="DistanceLabel" Text="0.0 km" FontSize="24" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="#111827" Stroke="#1F2937" StrokeThickness="1" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Duration" FontSize="12" TextColor="#94A3B8" />
                            <Label x:Name="DurationLabel" Text="0 min" FontSize="24" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                    <Border Grid.Column="0" BackgroundColor="#111827" Stroke="#1F2937" StrokeThickness="1" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="MetricTitleLabel" Text="Metric" FontSize="12" TextColor="#94A3B8" />
                            <Label x:Name="MetricValueLabel" Text="--" FontSize="24" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="#111827" Stroke="#1F2937" StrokeThickness="1" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Recorded path" FontSize="12" TextColor="#94A3B8" />
                            <Label x:Name="PathSummaryLabel" Text="0 points saved" FontSize="24" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border BackgroundColor="#111827" Stroke="#1F2937" StrokeThickness="1" Padding="16,14">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Route overview" FontSize="14" FontAttributes="Bold" TextColor="White" />
                        <Label x:Name="RouteOverviewLabel"
                               Text="Full recorded path highlighted from start to finish."
                               FontSize="13"
                               LineBreakMode="WordWrap"
                               TextColor="#CBD5E1" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FC5200" StrokeThickness="0" Padding="18,14" HeightRequest="54">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.ArrowBack}"
                                            FontSize="18"
                                            TextColor="#FFFFFF"
                                            VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="Back to activities"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#FFFFFF"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
