<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.FontSizeSelectionPage"
             Title="Font Size"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
        <Style x:Key="RowGridStyle" TargetType="Grid">
            <Setter Property="MinimumHeightRequest" Value="72" />
            <Setter Property="Padding" Value="18,14" />
        </Style>
        <Style x:Key="RowLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="#F8FAFC" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Font Size"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Tune the reading scale for summaries, labels, and workout details."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="14">

            <!-- Preview Section -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Preview Text"
                       FontSize="11"
                       TextColor="#64748B"
                       FontAttributes="Bold"
                       CharacterSpacing="1.2"
                       TextTransform="Uppercase" />
                <Border Stroke="#243041" StrokeThickness="1" Padding="16,14" BackgroundColor="#0F172A">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <Label x:Name="PreviewLabel"
                           Text="Your activity summary"
                           FontSize="16"
                           TextColor="#F8FAFC"
                           HorizontalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <!-- Slider -->
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="Small" FontSize="12" TextColor="#94A3B8" VerticalOptions="Center" />
                    <Slider Grid.Column="1"
                            x:Name="FontSlider"
                            Minimum="0"
                            Maximum="3"
                            Value="1"
                            ThumbColor="#FC5200"
                            MinimumTrackColor="#FC5200"
                            MaximumTrackColor="#334155"
                            ValueChanged="OnSliderValueChanged" />
                    <Label Grid.Column="2" Text="Large" FontSize="12" TextColor="#94A3B8" VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Label Text="Size presets"
                   FontSize="11"
                   TextColor="#64748B"
                   FontAttributes="Bold"
                   CharacterSpacing="1.2"
                   TextTransform="Uppercase" />

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Small -->
            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFontSizeSelected" CommandParameter="Small" />
                </Grid.GestureRecognizers>
                <Label Text="Small" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="SmallCheck" Text="●" FontSize="20" TextColor="#FC5200" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="False" />
                    <Label x:Name="SmallUncheck" Text="○" FontSize="20" TextColor="#475569" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="True" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Medium (Default) -->
            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFontSizeSelected" CommandParameter="Medium" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="Medium" FontSize="16" FontAttributes="Bold" TextColor="#F8FAFC" />
                    <Label Text="Default" FontSize="12" TextColor="#94A3B8" />
                </VerticalStackLayout>
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="MediumCheck" Text="●" FontSize="20" TextColor="#FC5200" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="True" />
                    <Label x:Name="MediumUncheck" Text="○" FontSize="20" TextColor="#475569" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="False" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Large -->
            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFontSizeSelected" CommandParameter="Large" />
                </Grid.GestureRecognizers>
                <Label Text="Large" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="LargeCheck" Text="●" FontSize="20" TextColor="#FC5200" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="False" />
                    <Label x:Name="LargeUncheck" Text="○" FontSize="20" TextColor="#475569" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="True" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Extra Large -->
            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFontSizeSelected" CommandParameter="Extra Large" />
                </Grid.GestureRecognizers>
                <Label Text="Extra Large" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="ExtraLargeCheck" Text="●" FontSize="20" TextColor="#FC5200" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="False" />
                    <Label x:Name="ExtraLargeUncheck" Text="○" FontSize="20" TextColor="#475569" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="True" />
                </Grid>
            </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
