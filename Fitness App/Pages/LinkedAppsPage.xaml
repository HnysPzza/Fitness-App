<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.LinkedAppsPage"
             Title="Linked Apps"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="#9E9E9E" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="16,20,16,8" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="0.5" />
            <Setter Property="Color" Value="#E0E0E0" />
            <Setter Property="Margin" Value="16,0,0,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,40">

            <!-- CONNECTED -->
            <Label Text="Connected" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Padding="16,0" HeightRequest="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Text="🍎" FontSize="28" VerticalOptions="Center" Margin="0,0,12,0" />
                <Label Grid.Column="1" Text="Apple Health" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="Unlink" Clicked="OnUnlinkAppleHealth"
                        BackgroundColor="Transparent"
                        TextColor="#E53935"
                        BorderColor="#E53935"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="13"
                        HeightRequest="36"
                        Padding="12,0" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- AVAILABLE TO CONNECT -->
            <Label Text="Available to Connect" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Padding="16,0" HeightRequest="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Text="🟢" FontSize="24" VerticalOptions="Center" Margin="0,0,12,0" />
                <Label Grid.Column="1" Text="Google Fit" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="Link" Clicked="OnLinkApp"
                        CommandParameter="Google Fit"
                        BackgroundColor="#FC5200"
                        TextColor="White"
                        CornerRadius="8"
                        FontSize="13"
                        HeightRequest="36"
                        Padding="12,0" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Padding="16,0" HeightRequest="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Text="🟠" FontSize="24" VerticalOptions="Center" Margin="0,0,12,0" />
                <Label Grid.Column="1" Text="Strava" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="Link" Clicked="OnLinkApp"
                        CommandParameter="Strava"
                        BackgroundColor="#FC5200"
                        TextColor="White"
                        CornerRadius="8"
                        FontSize="13"
                        HeightRequest="36"
                        Padding="12,0" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Padding="16,0" HeightRequest="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Text="⌚" FontSize="24" VerticalOptions="Center" Margin="0,0,12,0" />
                <Label Grid.Column="1" Text="Garmin Connect" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="Link" Clicked="OnLinkApp"
                        CommandParameter="Garmin Connect"
                        BackgroundColor="#FC5200"
                        TextColor="White"
                        CornerRadius="8"
                        FontSize="13"
                        HeightRequest="36"
                        Padding="12,0" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
