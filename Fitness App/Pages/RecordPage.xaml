<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             x:Class="Fitness_App.Pages.RecordPage"
             BackgroundColor="#000000"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- LAYER 0 - Map -->
        <WebView x:Name="MapWebView" />

        <!-- LAYER 1 - Top Bar & Scrim -->
        <VerticalStackLayout VerticalOptions="Start" InputTransparent="True" ZIndex="1">
            <Border StrokeThickness="0" BackgroundColor="Transparent" HeightRequest="90">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#99000000" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="*, Auto" Padding="20,44,20,0" VerticalOptions="Start">
                    <!-- Settings Button -->
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#441A1A2E"
                            WidthRequest="40" HeightRequest="40" VerticalOptions="Center" InputTransparent="False">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsTapped" />
                        </Border.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Settings}"
                                            FontSize="20" TextColor="White"
                                            HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Border>
        </VerticalStackLayout>



        <!-- LAYER 1.5 - Floating map controls -->
        <VerticalStackLayout ZIndex="2" Spacing="12" Margin="0,-40,16,0"
                             VerticalOptions="Center" HorizontalOptions="End" InputTransparent="False">
            <!-- Map style button -->
            <Border WidthRequest="44" HeightRequest="44"
                    BackgroundColor="#C0141414" Stroke="#14FFFFFF" StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="#000" Radius="12" Opacity="0.4" Offset="0,4" /></Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMapStyleTapped" />
                </Border.GestureRecognizers>
                <!-- Stack style map icon -->
                <Path Data="M 2 6 L 12 2 L 22 6 L 12 10 Z  M 2 12 L 12 16 L 22 12 M 2 18 L 12 22 L 22 18"
                      Fill="Transparent" Stroke="White" StrokeThickness="1.5"
                      HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="24" HeightRequest="24" />
            </Border>

            <!-- 3D toggle -->
            <Border WidthRequest="44" HeightRequest="44"
                    BackgroundColor="#C0141414" Stroke="#14FFFFFF" StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="#000" Radius="12" Opacity="0.4" Offset="0,4" /></Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThreeDTapped" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="-4" HorizontalOptions="Center" VerticalOptions="Center">
                    <Path x:Name="FloatingThreeDPath"
                          Data="M 4 10 L 20 10 L 16 2 L 8 2 Z M 12 2 L 12 10 M 6 6 L 18 6"
                          Fill="Transparent" Stroke="#FFFFFF" StrokeThickness="1.5"
                          WidthRequest="24" HeightRequest="12" Opacity="0.8" HorizontalOptions="Center" />
                    <Label x:Name="FloatingThreeDLabel" Text="3D" FontSize="9" FontAttributes="Bold" TextColor="#FFFFFF" Opacity="0.6" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- LAYER 2 - Main UI bottom layer -->
        <VerticalStackLayout VerticalOptions="End" Spacing="16" Margin="0,0,0,0" ZIndex="3">

            <!-- Combined Stats Card (Matches Image Design) -->
            <Border Margin="14,0,14,0" BackgroundColor="#22201D" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="#000" Radius="20" Opacity="0.4" Offset="0,8"/></Border.Shadow>

                <VerticalStackLayout Spacing="0">
                    <!-- GPS Header -->
                    <Grid x:Name="GpsStatusRow" BackgroundColor="#062F5E" Padding="14,10" ColumnDefinitions="Auto,*" HeightRequest="44">
                        <controls:IconLabel x:Name="GpsDot1" Text="{x:Static icons:MaterialSymbols.Signal_cellular_alt}"
                                            FontSize="18" TextColor="#60A5FA" VerticalOptions="Center" />
                        <Label x:Name="GpsStatusLabel" Grid.Column="1" Text="Searching for GPS..."
                               FontSize="14" FontAttributes="Bold" TextColor="#93C5FD"
                               VerticalOptions="Center" Margin="8,0,0,0" />
                    </Grid>

                    <!-- Stats Row -->
                    <Grid ColumnDefinitions="*,*,*" Padding="16,20" ColumnSpacing="0" BackgroundColor="#22201D">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="LiveTimeLabel" Text="00:00"
                                   FontSize="24" FontAttributes="Bold" TextColor="White"
                                   HorizontalOptions="Center" />
                            <Label Text="Time" FontSize="11" FontAttributes="Bold" TextColor="#A19D94" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="LiveDistanceLabel" Text="0"
                                   FontSize="32" FontAttributes="Bold" TextColor="White"
                                   HorizontalOptions="Center" Margin="0,-4,0,-4" />
                            <Label Text="Distance (km)" FontSize="11" FontAttributes="Bold" TextColor="#A19D94" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="LivePaceLabel" Text="--"
                                   FontSize="24" FontAttributes="Bold" TextColor="White"
                                   HorizontalOptions="Center" />
                            <Label x:Name="LiveMetricTitleLabel" Text="Pace (/km)"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="#A19D94" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Bottom CTA Bar -->
            <Border x:Name="BottomBar" BackgroundColor="#0F0F0F" StrokeThickness="0" Margin="0,-16,0,0" Padding="0,20,0,36">
                <Border.StrokeShape><RoundRectangle CornerRadius="28,28,0,0" /></Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A1A1A" Offset="0"/>
                        <GradientStop Color="#0A0A0A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="0">
                    <!-- 3-column CTA row -->
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0" Padding="24,0,24,0">

                        <!-- LEFT SLOT: Sport pill (idle) OR Finish button (recording) -->
                        <Grid HorizontalOptions="Center" VerticalOptions="Center">

                            <!-- Sport Selector (IDLE) -->
                            <VerticalStackLayout x:Name="SportSelectorBtn" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                <Grid WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                                    <Border WidthRequest="64" HeightRequest="64" BackgroundColor="#2A1608" StrokeThickness="1.5" Stroke="#FC5200">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                                        <Border.Shadow><Shadow Brush="#FC5200" Radius="10" Opacity="0.2" Offset="0,4" /></Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSportPillTapped" />
                                        </Border.GestureRecognizers>
                                        <Label x:Name="SelectedSportIconLabel"
                                               Text="{x:Static icons:MaterialSymbols.Directions_walk}"
                                               FontFamily="MaterialSymbols"
                                               FontSize="26"
                                               HorizontalOptions="Center" VerticalOptions="Center" TextColor="#FC5200" />
                                    </Border>
                                    <!-- Checkmark badge -->
                                    <Border WidthRequest="22" HeightRequest="22" BackgroundColor="#FC5200" Stroke="#0F0F0F" StrokeThickness="2"
                                            HorizontalOptions="End" VerticalOptions="Start" Margin="0,1,1,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="11" /></Border.StrokeShape>
                                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Check}" FontSize="11" TextColor="White"
                                                            HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                </Grid>
                                <Label x:Name="SelectedSportNameLabel" Text="Walk"
                                       FontSize="12" FontAttributes="Bold" TextColor="#CCCCCC"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <!-- Finish Button (RECORDING) -->
                            <VerticalStackLayout x:Name="FinishBtn" Spacing="8" IsVisible="False" HorizontalOptions="Center" VerticalOptions="Center">
                                <Grid WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                                    <!-- Red glow -->
                                    <Border WidthRequest="72" HeightRequest="72"
                                            StrokeThickness="0" Opacity="0.45" InputTransparent="True"
                                            HorizontalOptions="Center" VerticalOptions="Center">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="36" /></Border.StrokeShape>
                                        <Border.Background>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#88EF4444" Offset="0.3"/>
                                                <GradientStop Color="#00EF4444" Offset="1.0"/>
                                            </RadialGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- Button face -->
                                    <Border WidthRequest="64" HeightRequest="64"
                                            BackgroundColor="#1A0808" Stroke="#EF4444" StrokeThickness="1.5"
                                            HorizontalOptions="Center" VerticalOptions="Center">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                                        <Border.Shadow><Shadow Brush="#EF4444" Radius="14" Opacity="0.35" Offset="0,4" /></Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnRecordTapped" />
                                        </Border.GestureRecognizers>
                                        <!-- Square stop icon -->
                                        <BoxView WidthRequest="22" HeightRequest="22" CornerRadius="4"
                                                 Color="#EF4444" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                </Grid>
                                <Label Text="Finish" FontSize="12" FontAttributes="Bold" TextColor="#EF4444"
                                       HorizontalOptions="Center">
                                    <Label.Shadow><Shadow Brush="Black" Radius="2" Opacity="0.2" Offset="0,1" /></Label.Shadow>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- CENTER: Main record button -->
                        <Grid Grid.Column="1" WidthRequest="90" HeightRequest="90" HorizontalOptions="Center">
                            <!-- Ambient glow -->
                            <Border x:Name="RecordButtonGlow" WidthRequest="90" HeightRequest="90" StrokeThickness="0" Opacity="0" InputTransparent="True" BackgroundColor="Transparent">
                                <Border.StrokeShape><RoundRectangle CornerRadius="45" /></Border.StrokeShape>
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#CCFC4C02" Offset="0.2"/>
                                        <GradientStop Color="#00FC4C02" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- Pulse ring (visible when recording) -->
                            <Border x:Name="RecordPulseRing" WidthRequest="88" HeightRequest="88"
                                    HorizontalOptions="Center" VerticalOptions="Center"
                                    BackgroundColor="Transparent" Stroke="#66EF4444" StrokeThickness="1.5"
                                    Opacity="0" InputTransparent="True">
                                <Border.StrokeShape><RoundRectangle CornerRadius="44" /></Border.StrokeShape>
                            </Border>
                            <!-- Main button -->
                            <Border x:Name="RecordButton" WidthRequest="76" HeightRequest="76"
                                    HorizontalOptions="Center" VerticalOptions="Center"
                                    BackgroundColor="#FC5200" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="38" /></Border.StrokeShape>
                                <Border.Shadow><Shadow Brush="#FC5200" Radius="18" Opacity="0.45" Offset="0,6" /></Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRecordTapped" />
                                </Border.GestureRecognizers>
                                <controls:IconLabel x:Name="RecordButtonIconLabel"
                                                    Text="{x:Static icons:MaterialSymbols.Play_arrow}"
                                                    FontSize="34" TextColor="White"
                                                    HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <!-- RIGHT SLOT: Pause / Resume (visible during recording) -->
                        <Grid Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <VerticalStackLayout x:Name="PauseBtn" Spacing="8" IsVisible="False" HorizontalOptions="Center" VerticalOptions="Center">
                                <Grid WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                                    <!-- Amber glow -->
                                    <Border WidthRequest="72" HeightRequest="72"
                                            StrokeThickness="0" Opacity="0.5" InputTransparent="True"
                                            HorizontalOptions="Center" VerticalOptions="Center">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="36" /></Border.StrokeShape>
                                        <Border.Background>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#88F59E0B" Offset="0.3"/>
                                                <GradientStop Color="#00000000" Offset="1.0"/>
                                            </RadialGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- Button face -->
                                    <Border x:Name="PauseBtnFace" WidthRequest="64" HeightRequest="64"
                                            BackgroundColor="#1A1200" Stroke="#F59E0B" StrokeThickness="1.5"
                                            HorizontalOptions="Center" VerticalOptions="Center">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                                        <Border.Shadow><Shadow Brush="#F59E0B" Radius="14" Opacity="0.35" Offset="0,4" /></Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPauseTapped" />
                                        </Border.GestureRecognizers>
                                        <controls:IconLabel x:Name="PauseBtnIcon"
                                                            Text="{x:Static icons:MaterialSymbols.Pause}"
                                                            FontSize="28" TextColor="#FBBF24"
                                                            HorizontalOptions="Center" VerticalOptions="Center">
                                            <controls:IconLabel.Shadow>
                                                <Shadow Brush="Black" Radius="4" Opacity="0.3" Offset="0,2" />
                                            </controls:IconLabel.Shadow>
                                        </controls:IconLabel>
                                    </Border>
                                </Grid>
                                <Label x:Name="PauseBtnLabel"
                                       Text="Pause"
                                       FontSize="12" FontAttributes="Bold" TextColor="#FBBF24"
                                       HorizontalOptions="Center">
                                    <Label.Shadow><Shadow Brush="Black" Radius="2" Opacity="0.2" Offset="0,1" /></Label.Shadow>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Grid x:Name="MapStyleLayer"
              ZIndex="10"
              IsVisible="False"
              InputTransparent="True"
              CascadeInputTransparent="False">
            <Grid x:Name="MapStyleBackdrop"
                  ZIndex="0"
                  IsVisible="True"
                  BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMapStyleBackdropTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <Border x:Name="MapStyleSheet"
                    ZIndex="1"
                    IsVisible="True"
                    VerticalOptions="Start"
                    HorizontalOptions="End"
                    WidthRequest="292"
                    Margin="0,96,16,0"
                    Padding="12"
                    BackgroundColor="#E61A1A1A"
                    Stroke="#33FFFFFF"
                    StrokeThickness="1"
                    TranslationY="-16"
                    Opacity="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Radius="18" Opacity="0.45" Offset="0,6" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Map Style" FontSize="15" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Choose how the recording map looks." FontSize="11" TextColor="#B8FFFFFF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="30" HeightRequest="30"
                                BackgroundColor="#22FFFFFF" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMapStyleBackdropTapped" />
                            </Border.GestureRecognizers>
                            <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Close}"
                                                FontSize="16"
                                                TextColor="White"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="8"
                          RowSpacing="8">
                        <Border x:Name="RecOutdoorsCard" Padding="0" HeightRequest="92"
                                BackgroundColor="#202020" Stroke="#00000000" StrokeThickness="2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRecOutdoorsTapped" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*,24">
                                <Image Source="map_style_outdoors.jpg" Aspect="AspectFill" />
                                <Label x:Name="RecOutdoorsCheck" Grid.Row="1" Text="Outdoors"
                                       FontSize="11" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border x:Name="RecOutdoorsBadge" IsVisible="False" WidthRequest="20" HeightRequest="20"
                                        BackgroundColor="#FC5200" Stroke="#111111" StrokeThickness="1"
                                        HorizontalOptions="End" VerticalOptions="Start" Margin="0,4,4,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Check}" FontSize="12" TextColor="White"
                                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="RecStreetsCard" Grid.Column="1" Padding="0" HeightRequest="92"
                                BackgroundColor="#202020" Stroke="#00000000" StrokeThickness="2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRecStreetsTapped" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*,24">
                                <Image Source="map_style_streets.jpg" Aspect="AspectFill" />
                                <Label x:Name="RecStreetsCheck" Grid.Row="1" Text="Standard"
                                       FontSize="11" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border x:Name="RecStreetsBadge" IsVisible="False" WidthRequest="20" HeightRequest="20"
                                        BackgroundColor="#FC5200" Stroke="#111111" StrokeThickness="1"
                                        HorizontalOptions="End" VerticalOptions="Start" Margin="0,4,4,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Check}" FontSize="12" TextColor="White"
                                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="RecSatelliteCard" Grid.Row="1" Padding="0" HeightRequest="92"
                                BackgroundColor="#202020" Stroke="#00000000" StrokeThickness="2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRecSatelliteTapped" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*,24">
                                <Image Source="map_style_satellite.jpg" Aspect="AspectFill" />
                                <Label x:Name="RecSatelliteCheck" Grid.Row="1" Text="Satellite"
                                       FontSize="11" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border x:Name="RecSatelliteBadge" IsVisible="False" WidthRequest="20" HeightRequest="20"
                                        BackgroundColor="#FC5200" Stroke="#111111" StrokeThickness="1"
                                        HorizontalOptions="End" VerticalOptions="Start" Margin="0,4,4,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Check}" FontSize="12" TextColor="White"
                                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="RecDarkCard" Grid.Row="1" Grid.Column="1" Padding="0" HeightRequest="92"
                                BackgroundColor="#202020" Stroke="#00000000" StrokeThickness="2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRecDarkTapped" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*,24">
                                <Image Source="map_style_dark.jpg" Aspect="AspectFill" />
                                <Label x:Name="RecDarkCheck" Grid.Row="1" Text="Dark"
                                       FontSize="11" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border x:Name="RecDarkBadge" IsVisible="False" WidthRequest="20" HeightRequest="20"
                                        BackgroundColor="#FC5200" Stroke="#111111" StrokeThickness="1"
                                        HorizontalOptions="End" VerticalOptions="Start" Margin="0,4,4,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Check}" FontSize="12" TextColor="White"
                                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="RecLightCard" Grid.Row="2" Padding="0" HeightRequest="92"
                                BackgroundColor="#202020" Stroke="#00000000" StrokeThickness="2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRecLightTapped" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*,24">
                                <Image Source="map_style_light.jpg" Aspect="AspectFill" />
                                <Label x:Name="RecLightCheck" Grid.Row="1" Text="Light"
                                       FontSize="11" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border x:Name="RecLightBadge" IsVisible="False" WidthRequest="20" HeightRequest="20"
                                        BackgroundColor="#FC5200" Stroke="#111111" StrokeThickness="1"
                                        HorizontalOptions="End" VerticalOptions="Start" Margin="0,4,4,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Check}" FontSize="12" TextColor="White"
                                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Expanded Sport Sheet -->
        <Border x:Name="ExpandedSheet" ZIndex="11" BackgroundColor="#1C1C2E" VerticalOptions="End" HeightRequest="580"
                StrokeThickness="0" IsVisible="False" TranslationY="600">
            <Border.StrokeShape><RoundRectangle CornerRadius="28,28,0,0" /></Border.StrokeShape>
            <Border.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnExpandedSheetPanUpdated" />
            </Border.GestureRecognizers>
            <Grid RowDefinitions="Auto,Auto,*" Padding="20,12,20,0">
                <BoxView Grid.Row="0" HeightRequest="4" WidthRequest="36" CornerRadius="2" Color="#3A3A5C" HorizontalOptions="Center" Margin="0,0,0,14">
                    <BoxView.GestureRecognizers><TapGestureRecognizer Tapped="OnCollapseTapped" /></BoxView.GestureRecognizers>
                </BoxView>
                <Border Grid.Row="1" BackgroundColor="#2A2A3E" StrokeThickness="0" HeightRequest="44" Margin="0,0,0,12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" Padding="12,0">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Search}" TextColor="#64748B" FontSize="20" VerticalOptions="Center" />
                        <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="Search activities..." PlaceholderColor="#64748B" TextColor="White" BackgroundColor="Transparent" TextChanged="OnSearchTextChanged" />
                    </Grid>
                </Border>
                <CollectionView Grid.Row="2" ItemsSource="{Binding FilteredSportGroups}" IsGrouped="True" SelectionMode="Single" SelectionChanged="OnSportItemSelected">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Category}" FontSize="10" FontAttributes="Bold" TextColor="#64748B" CharacterSpacing="1.5" Margin="0,10,0,4" />
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" HeightRequest="52" Margin="0,0,0,4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#2AFC4C02" />
                                        <Setter Property="Stroke" Value="#FC4C02" />
                                        <Setter Property="StrokeThickness" Value="1.5" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#2A2A3E" />
                                        <Setter Property="StrokeThickness" Value="0" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Grid ColumnDefinitions="Auto,*" Padding="14,0">
                                    <Label Text="{Binding Icon}" FontFamily="MaterialSymbols" FontSize="20" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Name}" FontSize="14" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" Margin="12,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- Finish Confirm Sheet -->
        <Grid x:Name="FinishBackdrop" IsVisible="False" InputTransparent="False" ZIndex="12" BackgroundColor="#88000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnFinishBackdropTapped" />
            </Grid.GestureRecognizers>
        </Grid>
        <Border x:Name="FinishConfirmSheet" ZIndex="13" BackgroundColor="#1E293B" VerticalOptions="End" HeightRequest="380"
                StrokeThickness="0" IsVisible="False" TranslationY="350" Padding="24">
            <Border.StrokeShape><RoundRectangle CornerRadius="28,28,0,0" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="0">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,24">
                    <Label Text="Finish Workout?" FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Border Grid.Column="1" WidthRequest="36" HeightRequest="36" BackgroundColor="#334155" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnKeepRecordingClicked" /></Border.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Close}" FontSize="14" TextColor="#94A3B8" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,24">
                    <Border Padding="16" BackgroundColor="#0F172A" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Time" FontSize="12" TextColor="#64748B" />
                            <Label x:Name="FinishTimeLabel" Text="00:00:00" FontSize="16" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Padding="16" BackgroundColor="#0F172A" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Distance" FontSize="12" TextColor="#64748B" />
                            <HorizontalStackLayout Spacing="4" VerticalOptions="End">
                                <Label x:Name="FinishDistanceLabel" Text="0.00" FontSize="16" FontAttributes="Bold" TextColor="#10B981" />
                                <Label Text="km" FontSize="12" TextColor="#10B981" VerticalOptions="End" Margin="0,0,0,2" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
                <Button Text="Keep Recording" BackgroundColor="#0F172A" TextColor="White" FontSize="15" FontAttributes="Bold" HeightRequest="52" CornerRadius="16" Margin="0,0,0,12" Clicked="OnKeepRecordingClicked" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Text="Discard" BackgroundColor="#334155" TextColor="#FCA5A5" FontSize="15" FontAttributes="Bold" HeightRequest="54" CornerRadius="16" Clicked="OnDiscardActivityClicked" />
                    <Button Grid.Column="1" Text="Save Activity" BackgroundColor="#10B981" TextColor="White" FontSize="15" FontAttributes="Bold" HeightRequest="54" CornerRadius="16" Clicked="OnSaveActivityClicked" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Saved Success Overlay -->
        <Grid x:Name="SavedBackdrop" IsVisible="False" InputTransparent="False" ZIndex="14" BackgroundColor="#88000000" />
        <Border x:Name="SavedSheet" ZIndex="15" BackgroundColor="#10B981" VerticalOptions="Center" HeightRequest="200" WidthRequest="260" HorizontalOptions="Center"
                StrokeThickness="0" IsVisible="False" TranslationY="600">
            <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Check_circle}" FontSize="56" TextColor="White" HorizontalOptions="Center" />
                <Label x:Name="SavedSportLabel" Text="Workout" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label x:Name="SavedTimeLabel" Text="00:00:00" FontSize="14" TextColor="White" />
                    <Label Text="|" FontSize="14" TextColor="#D1FAE5" />
                    <Label x:Name="SavedDistanceLabel" Text="0.00 km" FontSize="14" TextColor="White" />
                </HorizontalStackLayout>
                <Button Text="Done" BackgroundColor="#059669" TextColor="White" CornerRadius="12" HeightRequest="40" Margin="0,8,0,0" Clicked="OnDoneClicked" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
