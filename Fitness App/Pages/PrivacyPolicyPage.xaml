<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.PrivacyPolicyPage"
             Title="Privacy Policy"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,40" Spacing="16">

            <Label Text="Last updated: January 1, 2025"
                   FontSize="13"
                   TextColor="#9E9E9E" />

            <Label Text="Privacy Policy"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

            <Label TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" FontSize="15" LineBreakMode="WordWrap">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="1. Information We Collect&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="We collect information you provide directly to us, such as when you create an account, record an activity, or contact us for support. This includes: name, email address, profile photo, fitness activities, GPS routes, and device information.&#10;&#10;" />
                        <Span Text="2. How We Use Your Information&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="We use the information we collect to provide, maintain, and improve the Fitness App, process your activity data, send notifications and reminders, and personalize your experience.&#10;&#10;" />
                        <Span Text="3. Information Sharing&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="We do not sell, trade, or otherwise transfer your personal information to third parties without your consent, except as described in this policy. We may share information with service providers that assist in our operations.&#10;&#10;" />
                        <Span Text="4. Data Security&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="We implement appropriate technical and organizational measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction.&#10;&#10;" />
                        <Span Text="5. Location Data&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="With your permission, we collect precise location data when you record activities. This data is stored securely on our servers. You can disable location access in your device settings at any time.&#10;&#10;" />
                        <Span Text="6. Your Rights&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="You have the right to access, correct, or delete your personal data. You can manage your data through the app settings or by contacting us at privacy@fitnessapp.com.&#10;&#10;" />
                        <Span Text="7. Data Retention&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="We retain your personal information for as long as your account is active. If you delete your account, we will delete your data within 30 days, subject to legal obligations.&#10;&#10;" />
                        <Span Text="8. Contact Us&#10;&#10;" FontAttributes="Bold" />
                        <Span Text="If you have questions about this Privacy Policy, please contact us at privacy@fitnessapp.com." />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <BoxView HeightRequest="0.5" Color="#E0E0E0" Margin="0,8,0,8" />

            <Button Text="Open in Browser"
                    Clicked="OnOpenInBrowser"
                    BackgroundColor="Transparent"
                    TextColor="#FC5200"
                    BorderColor="#FC5200"
                    BorderWidth="1.5"
                    CornerRadius="10"
                    FontSize="15"
                    HeightRequest="44" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
