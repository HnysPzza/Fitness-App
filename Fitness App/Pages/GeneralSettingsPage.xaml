<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             x:Class="Fitness_App.Pages.GeneralSettingsPage"
             Title="General Settings"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="#64748B" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="28,24,24,8" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>

        <Style x:Key="RowGridStyle" TargetType="Grid">
            <Setter Property="HeightRequest" Value="62" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="ColumnDefinitions" Value="Auto,*,Auto" />
        </Style>

        <Style x:Key="SettingsIconStyle" TargetType="controls:IconLabel">
            <Setter Property="FontSize" Value="21" />
            <Setter Property="TextColor" Value="#94A3B8" />
            <Setter Property="WidthRequest" Value="34" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <Style x:Key="RowLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <Style x:Key="ChevronStyle" TargetType="controls:IconLabel">
            <Setter Property="Text" Value="{x:Static icons:MaterialSymbols.Chevron_right}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="TextColor" Value="#475569" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#0F172A" />
            <Setter Property="Margin" Value="50,0,0,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,12,0,60">

            <!-- HEADER -->
            <Grid HeightRequest="0"
                  Padding="0"
                  IsVisible="False" />

            <!-- ══ NOTIFICATIONS ══ -->
            <Label Text="Notifications" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0"
                    Padding="0"
                    BackgroundColor="#1E293B"
                    Stroke="#334155"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <!-- Push Notifications -->
                    <Grid Style="{StaticResource RowGridStyle}">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Notifications_active}"
                                            Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Push Notifications" Style="{StaticResource RowLabelStyle}" />
                        <Switch x:Name="PushNotificationsSwitch"
                                Grid.Column="2"
                                IsToggled="True"
                                VerticalOptions="Center"
                                OnColor="#FC5200"
                                Toggled="OnPushNotificationsToggled" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <!-- Workout Reminders -->
                    <Grid x:Name="WorkoutRemindersRow" Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnWorkoutRemindersDetail" />
                        </Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Alarm}"
                                            Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Workout Reminders" Style="{StaticResource RowLabelStyle}" />
                        <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                            <Switch x:Name="WorkoutRemindersSwitch"
                                    IsToggled="True"
                                    VerticalOptions="Center"
                                    OnColor="#FC5200"
                                    Toggled="OnWorkoutRemindersToggled" />
                            <controls:IconLabel Style="{StaticResource ChevronStyle}" />
                        </HorizontalStackLayout>
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <!-- Achievement Alerts -->
                    <Grid x:Name="AchievementAlertsRow" Style="{StaticResource RowGridStyle}">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Emoji_events}"
                                            Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Achievement Alerts" Style="{StaticResource RowLabelStyle}" />
                        <Switch x:Name="AchievementAlertsSwitch"
                                Grid.Column="2"
                                IsToggled="True"
                                VerticalOptions="Center"
                                OnColor="#FC5200"
                                Toggled="OnAchievementAlertsToggled" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <!-- Weekly Summary -->
                    <Grid x:Name="WeeklySummaryRow" Style="{StaticResource RowGridStyle}">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Insights}"
                                            Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Weekly Summary" Style="{StaticResource RowLabelStyle}" />
                        <Switch x:Name="WeeklySummarySwitch"
                                Grid.Column="2"
                                IsToggled="True"
                                VerticalOptions="Center"
                                OnColor="#FC5200"
                                Toggled="OnWeeklySummaryToggled" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══ APPEARANCE ══ -->
            <Label Text="Appearance" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0" Padding="0" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnThemeTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Dark_mode}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Theme" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnAccentColorTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Colorize}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Accent Color" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnFontSizeTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Format_size}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Font Size" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══ LANGUAGE & REGION ══ -->
            <Label Text="Language &amp; Region" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0" Padding="0" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnLanguageTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Language}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Language" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnUnitsTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Straighten}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Units" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnDateTimeTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Schedule}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Date &amp; Time Format" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══ PRIVACY & SECURITY ══ -->
            <Label Text="Privacy &amp; Security" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0" Padding="0" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnChangePasswordTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Password}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Change Password" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnTwoFactorTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Security}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Two-Factor Authentication" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnDataSharingTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Share}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Data Sharing" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnDownloadDataTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Download}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Download My Data" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══ ACCESSIBILITY ══ -->
            <Label Text="Accessibility" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0" Padding="0" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <Grid Style="{StaticResource RowGridStyle}">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Settings_accessibility}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Screen Reader" Style="{StaticResource RowLabelStyle}" />
                        <Switch x:Name="ScreenReaderSwitch"
                                Grid.Column="2"
                                IsToggled="False"
                                VerticalOptions="Center"
                                OnColor="#FC5200"
                                Toggled="OnScreenReaderToggled" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Contrast}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="High Contrast Mode" Style="{StaticResource RowLabelStyle}" />
                        <Switch x:Name="HighContrastSwitch"
                                Grid.Column="2"
                                IsToggled="False"
                                VerticalOptions="Center"
                                OnColor="#FC5200"
                                Toggled="OnHighContrastToggled" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Slow_motion_video}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Reduce Motion" Style="{StaticResource RowLabelStyle}" />
                        <Switch x:Name="ReduceMotionSwitch"
                                Grid.Column="2"
                                IsToggled="False"
                                VerticalOptions="Center"
                                OnColor="#FC5200"
                                Toggled="OnReduceMotionToggled" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══ CONNECTED SERVICES ══ -->
            <Label Text="Connected Services" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0" Padding="0" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnLinkedAppsTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Apps}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Linked Apps" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnWearableDevicesTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Watch}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Wearable Devices" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══ ABOUT & SUPPORT ══ -->
            <Label Text="About &amp; Support" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0" Padding="0" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAppVersionLongPress" NumberOfTapsRequired="2" />
                        </Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Info}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="App Version" Style="{StaticResource RowLabelStyle}" />
                        <Label Grid.Column="2"
                               Text="1.0.0"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#475569"
                               VerticalOptions="Center" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnHelpFaqTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Help}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Help &amp; FAQ" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnSendFeedbackTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Feedback}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Send Feedback" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnRateTheAppTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Star}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Rate the App" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnTermsOfServiceTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Gavel}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Terms of Service" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnPrivacyPolicyTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Policy}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Privacy Policy" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══ ACCOUNT ══ -->
            <Label Text="Account" Style="{StaticResource SectionHeaderStyle}" />

            <Border Margin="16,0" Padding="0" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnSwitchAccountTapped" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Switch_account}" Style="{StaticResource SettingsIconStyle}" />
                        <Label Grid.Column="1" Text="Switch Account" Style="{StaticResource RowLabelStyle}" />
                        <controls:IconLabel Grid.Column="2" Style="{StaticResource ChevronStyle}" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerStyle}" />

                    <Grid Style="{StaticResource RowGridStyle}">
                        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnDeleteAccountClicked" /></Grid.GestureRecognizers>
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Delete}"
                                            FontSize="21"
                                            TextColor="#EF4444"
                                            WidthRequest="34"
                                            VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="Delete Account"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#EF4444"
                               VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Log Out -->
            <Button Text="Log Out"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="18"
                    HeightRequest="56"
                    Margin="16,28,16,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
