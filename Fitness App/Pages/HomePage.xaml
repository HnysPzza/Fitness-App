<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Fitness_App.UI.Controls"
             xmlns:icons="clr-namespace:Fitness_App.UI.Icons"
             x:Class="Fitness_App.Pages.HomePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F6F8FB, Dark=#0B0F19}">

    <ScrollView>
        <Grid Padding="20,18,20,92"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              RowSpacing="18">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="3"
                                     VerticalOptions="Center">
                    <Label x:Name="GreetingLabel"
                           Text="Good morning"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    <Label x:Name="HomeUserNameLabel"
                           Text="Athlete"
                           FontSize="28"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        WidthRequest="48"
                        HeightRequest="48"
                        Padding="0"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#243044}"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReminderTapped" />
                    </Border.GestureRecognizers>
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Notifications_active}"
                                        FontSize="22"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        TextColor="#FC5200" />
                </Border>

                <Border Grid.Column="2"
                        WidthRequest="48"
                        HeightRequest="48"
                        Padding="0"
                        StrokeThickness="0"
                        BackgroundColor="#FC5200">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#FC5200"
                                Radius="18"
                                Opacity="0.28"
                                Offset="0,6" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsClicked" />
                    </Border.GestureRecognizers>
                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Person}"
                                        FontSize="22"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        TextColor="#FFFFFF" />
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Padding="22"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#FC5200"
                            Radius="28"
                            Opacity="0.18"
                            Offset="0,10" />
                </Border.Shadow>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#FC5200"
                                      Offset="0" />
                        <GradientStop Color="#FF7A1A"
                                      Offset="0.56" />
                        <GradientStop Color="#D84300"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="18">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="This week"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#FFE7D5" />
                            <Label Text="{Binding WeekDistance, StringFormat='{}{0} km'}"
                                   FontSize="44"
                                   FontAttributes="Bold"
                                   LineHeight="0.95"
                                   TextColor="#FFFFFF" />
                            <Label Text="{Binding WeekDeltaText}"
                                   FontSize="13"
                                   TextColor="#FFE7D5"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                WidthRequest="54"
                                HeightRequest="54"
                                Padding="0"
                                StrokeThickness="1"
                                Stroke="#35FFFFFF"
                                BackgroundColor="#26FFFFFF">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Trending_up}"
                                                FontSize="26"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                TextColor="#FFFFFF" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Border Padding="14,12"
                                StrokeThickness="1"
                                Stroke="#22FFFFFF"
                                BackgroundColor="#1FFFFFFF">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Sessions"
                                       FontSize="12"
                                       TextColor="#FFD4B8" />
                                <Label Text="{Binding WeekActivities}"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="14,12"
                                StrokeThickness="1"
                                Stroke="#22FFFFFF"
                                BackgroundColor="#1FFFFFFF">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Active time"
                                       FontSize="12"
                                       TextColor="#FFD4B8" />
                                <Label Text="{Binding WeekTime}"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Button Grid.Row="2"
                            Text="Start a workout"
                            Clicked="OnStartWorkoutClicked"
                            HeightRequest="54"
                            CornerRadius="18"
                            Padding="18,0"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#0F172A"
                            BackgroundColor="#FFFFFF" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
                <Border Padding="14,12"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#171F2D}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReminderTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="10">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Alarm}"
                                            FontSize="22"
                                            VerticalOptions="Center"
                                            TextColor="#FC5200" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="1"
                                             VerticalOptions="Center">
                            <Label Text="Workout reminder"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#9A3412, Dark=#FDBA74}" />
                            <Label Text="{Binding ReminderSummary}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   MaxLines="1"
                                   LineBreakMode="TailTruncation"
                                   TextColor="{AppThemeBinding Light=#431407, Dark=#FFEDD5}" />
                        </VerticalStackLayout>
                        <controls:IconLabel Grid.Column="2"
                                            Text="{x:Static icons:MaterialSymbols.Chevron_right}"
                                            FontSize="20"
                                            VerticalOptions="Center"
                                            TextColor="#FC5200" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        WidthRequest="92"
                        Padding="12"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#131C2E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2"
                                         HorizontalOptions="Center">
                        <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Local_fire_department}"
                                            FontSize="20"
                                            TextColor="#FB923C" />
                        <Label Text="{Binding CurrentStreak, StringFormat='{}{0}d'}"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#FFFFFF}" />
                        <Label Text="streak"
                               FontSize="11"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <VerticalStackLayout Grid.Row="3"
                                 Spacing="18">
                <Border Padding="18"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding CurrentPlanTitle}"
                                       FontSize="19"
                                       FontAttributes="Bold"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                                <Label Text="{Binding CurrentPlanSummary}"
                                       FontSize="13"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Custom"
                                    Clicked="OnCreateCustomPlanClicked"
                                    HeightRequest="44"
                                    CornerRadius="16"
                                    Padding="14,0"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    TextColor="#FC5200"
                                    BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#2B1E13}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <Label Text="{Binding CurrentPlanDuration}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            <Border Grid.Column="1"
                                    Padding="10,6"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#F0FDF4, Dark=#1B2E23}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Label Text="{Binding CurrentPlanProgress}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#10B981" />
                            </Border>
                        </Grid>

                        <CollectionView ItemsSource="{Binding CurrentPlanWorkouts}"
                                        SelectionMode="None"
                                        HeightRequest="196"
                                        IsVisible="{Binding HasWorkoutPlan}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12,10"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#182235}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPlanWorkoutTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="12">
                                            <Border WidthRequest="38"
                                                    HeightRequest="38"
                                                    Padding="0"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#2B1E13}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding DayLabel}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       TextColor="#FC5200" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Title}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                                                <Label Text="{Binding Sport}"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" />
                                                <Label Text="{Binding TargetLabel}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="#FC5200" />
                                            </VerticalStackLayout>
                                            <controls:IconLabel Grid.Column="2"
                                                                Text="{x:Static icons:MaterialSymbols.Check_circle}"
                                                                FontSize="21"
                                                                VerticalOptions="Center"
                                                                TextColor="#10B981" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="Templates"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />

                        <CollectionView ItemsSource="{Binding PlanTemplates}"
                                        HeightRequest="104"
                                        HorizontalScrollBarVisibility="Never"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="12" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border WidthRequest="198"
                                            Padding="14,12"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#182235}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPlanTemplateTapped" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="5">
                                            <Label Text="{Binding Title}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   MaxLines="1"
                                                   LineBreakMode="TailTruncation"
                                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                                            <Label Text="{Binding Description}"
                                                   FontSize="12"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation"
                                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                            <Label Text="{Binding DurationDays, StringFormat='{}{0} day plan'}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="#FC5200" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="4"
                                 Spacing="16">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Suggested routes"
                               FontAttributes="Bold"
                               FontSize="20"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                        <Label Text="Popular trails near you"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    </VerticalStackLayout>

                    <Border Grid.Column="1"
                            Padding="12,8"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#243044}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="Explore"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                   VerticalOptions="Center" />
                            <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Chevron_right}"
                                                FontSize="18"
                                                TextColor="#FC5200"
                                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <CollectionView ItemsSource="{Binding SuggestedLocations}"
                                HeightRequest="206"
                                HorizontalScrollBarVisibility="Never"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="320"
                                    Padding="0"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#243044}"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#131C2E}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#0F172A, Dark=#000000}"
                                            Radius="20"
                                            Opacity="0.1"
                                            Offset="0,8" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLocationCardTapped" />
                                </Border.GestureRecognizers>

                                <Grid RowDefinitions="104,*"
                                      RowSpacing="0">
                                    <Border Grid.Row="0"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="26,26,0,0" />
                                        </Border.StrokeShape>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                                 EndPoint="1,1">
                                                <GradientStop Color="#111827"
                                                              Offset="0" />
                                                <GradientStop Color="#FC5200"
                                                              Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid Padding="18,16">
                                            <Border HeightRequest="44"
                                                    WidthRequest="44"
                                                    Padding="0"
                                                    StrokeThickness="1"
                                                    Stroke="#35FFFFFF"
                                                    BackgroundColor="#26FFFFFF"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="Start">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14" />
                                                </Border.StrokeShape>
                                                <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Location_on}"
                                                                    FontSize="23"
                                                                    TextColor="White"
                                                                    HorizontalOptions="Center"
                                                                    VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <VerticalStackLayout Grid.Row="1"
                                                         Padding="18,14,18,18"
                                                         Spacing="11">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="17"
                                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />

                                        <Grid ColumnDefinitions="Auto,Auto,*"
                                              ColumnSpacing="10">
                                            <Border Padding="10,6"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light=#F0FDF4, Dark=#1B2E23}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="5">
                                                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Route}"
                                                                        FontSize="15"
                                                                        TextColor="#10B981"
                                                                        VerticalOptions="Center" />
                                                    <Label Text="{Binding DistanceKm, StringFormat='{0:F1} km'}"
                                                           TextColor="#10B981"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Padding="10,6"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#2B1E13}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="5">
                                                    <controls:IconLabel Text="{x:Static icons:MaterialSymbols.Schedule}"
                                                                        FontSize="15"
                                                                        TextColor="#FC5200"
                                                                        VerticalOptions="Center" />
                                                    <Label Text="{Binding EstimatedMinutes, StringFormat='~{0} min'}"
                                                           TextColor="#FC5200"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
