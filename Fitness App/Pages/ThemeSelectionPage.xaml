<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.ThemeSelectionPage"
             Title="Theme"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="#64748B" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="0,0,0,8" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="RowGridStyle" TargetType="Grid">
            <Setter Property="MinimumHeightRequest" Value="74" />
            <Setter Property="Padding" Value="18,14" />
        </Style>
        <Style x:Key="RowLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="#F8FAFC" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Theme"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Choose the app appearance that fits your day and your environment."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Display mode" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <!-- Light -->
            <Grid x:Name="LightRow" Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemeSelected" CommandParameter="Light" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2">
                    <Label Text="Light" Style="{StaticResource RowLabelStyle}" />
                    <Label Text="Bright, clear surfaces for daylight use"
                           FontSize="12"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="LightCheck"
                           Text="●"
                           FontSize="20"
                           TextColor="#FC5200"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           IsVisible="False" />
                    <Label x:Name="LightUncheck"
                           Text="○"
                           FontSize="20"
                           TextColor="#475569"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           IsVisible="True" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Dark -->
            <Grid x:Name="DarkRow" Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemeSelected" CommandParameter="Dark" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2">
                    <Label Text="Dark" Style="{StaticResource RowLabelStyle}" />
                    <Label Text="Premium contrast for night rides and low light"
                           FontSize="12"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="DarkCheck"
                           Text="●"
                           FontSize="20"
                           TextColor="#FC5200"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           IsVisible="False" />
                    <Label x:Name="DarkUncheck"
                           Text="○"
                           FontSize="20"
                           TextColor="#475569"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           IsVisible="True" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- System Default -->
            <Grid x:Name="SystemRow" Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemeSelected" CommandParameter="System Default" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="2">
                    <Label Text="System Default" Style="{StaticResource RowLabelStyle}" />
                    <Label Text="Automatically follow your device appearance"
                           FontSize="12"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="SystemCheck"
                           Text="●"
                           FontSize="20"
                           TextColor="#FC5200"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           IsVisible="True" />
                    <Label x:Name="SystemUncheck"
                           Text="○"
                           FontSize="20"
                           TextColor="#475569"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           IsVisible="False" />
                </Grid>
            </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
