<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.ThemeSelectionPage"
             Title="Theme"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="#9E9E9E" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="16,20,16,8" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="RowGridStyle" TargetType="Grid">
            <Setter Property="HeightRequest" Value="56" />
            <Setter Property="Padding" Value="16,0" />
        </Style>
        <Style x:Key="RowLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="0.5" />
            <Setter Property="Color" Value="#E0E0E0" />
            <Setter Property="Margin" Value="16,0,0,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,40">

            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Light -->
            <Grid x:Name="LightRow" Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemeSelected" CommandParameter="Light" />
                </Grid.GestureRecognizers>
                <Label Text="Light" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="LightCheck"
                       Text="●"
                       FontSize="20"
                       TextColor="#FC5200"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       IsVisible="False" />
                <Label x:Name="LightUncheck"
                       Text="○"
                       FontSize="20"
                       TextColor="#BDBDBD"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       IsVisible="True" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Dark -->
            <Grid x:Name="DarkRow" Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemeSelected" CommandParameter="Dark" />
                </Grid.GestureRecognizers>
                <Label Text="Dark" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="DarkCheck"
                       Text="●"
                       FontSize="20"
                       TextColor="#FC5200"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       IsVisible="False" />
                <Label x:Name="DarkUncheck"
                       Text="○"
                       FontSize="20"
                       TextColor="#BDBDBD"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       IsVisible="True" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- System Default -->
            <Grid x:Name="SystemRow" Style="{StaticResource RowGridStyle}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemeSelected" CommandParameter="System Default" />
                </Grid.GestureRecognizers>
                <Label Text="System Default" Style="{StaticResource RowLabelStyle}" />
                <Label x:Name="SystemCheck"
                       Text="●"
                       FontSize="20"
                       TextColor="#FC5200"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       IsVisible="True" />
                <Label x:Name="SystemUncheck"
                       Text="○"
                       FontSize="20"
                       TextColor="#BDBDBD"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       IsVisible="False" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
