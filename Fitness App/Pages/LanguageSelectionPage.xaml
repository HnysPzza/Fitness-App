<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.LanguageSelectionPage"
             Title="Language"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout Spacing="16" Padding="16,18,16,28">

        <Border Padding="18"
                BackgroundColor="#111827"
                Stroke="#243041"
                StrokeThickness="1">
            <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
            <VerticalStackLayout Spacing="4">
                <Label Text="Language"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#F8FAFC" />
                <Label Text="Choose the language used for labels, menus, and coaching text."
                       FontSize="13"
                       TextColor="#94A3B8" />
            </VerticalStackLayout>
        </Border>

        <Border Padding="18"
                BackgroundColor="#111827"
                Stroke="#243041"
                StrokeThickness="1">
            <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
            <VerticalStackLayout Spacing="4">
                <Label Text="Current selection"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="1.2"
                       TextTransform="Uppercase"
                       TextColor="#64748B" />
                <Label x:Name="CurrentLanguageLabel"
                       Text="English"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#F8FAFC" />
            </VerticalStackLayout>
        </Border>

        <!-- Search Bar -->
        <Border Stroke="#243041" StrokeThickness="1" Padding="14,10" BackgroundColor="#111827">
            <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Label Grid.Column="0" Text="🔍" FontSize="16" VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       Placeholder="Search languages..."
                       PlaceholderColor="#64748B"
                       TextColor="#F8FAFC"
                       BackgroundColor="Transparent"
                       TextChanged="OnSearchTextChanged" />
            </Grid>
        </Border>

        <Border Padding="0"
                BackgroundColor="#111827"
                Stroke="#243041"
                StrokeThickness="1">
            <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
            <CollectionView x:Name="LanguageList"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <VerticalStackLayout>
                            <Grid HeightRequest="64" Padding="18,0" ColumnDefinitions="*,Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLanguageSelected" CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                                <Label Text="{Binding .}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#F8FAFC"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="›"
                                       FontSize="20"
                                       TextColor="#64748B"
                                       VerticalOptions="Center" />
                            </Grid>
                            <BoxView Style="{StaticResource DividerStyle}" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

    </VerticalStackLayout>
</ContentPage>
