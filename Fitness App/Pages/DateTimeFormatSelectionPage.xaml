<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.DateTimeFormatSelectionPage"
             Title="Date &amp; Time Format"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="#64748B" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="0,0,0,8" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="RowGridStyle" TargetType="Grid">
            <Setter Property="MinimumHeightRequest" Value="70" />
            <Setter Property="Padding" Value="18,14" />
        </Style>
        <Style x:Key="RowLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="#F8FAFC" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Date &amp; Time Format"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Choose how dates and time appear across training summaries and reminders."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <!-- Date Format -->
            <Label Text="Date Format" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDateFormatSelected" CommandParameter="DD/MM/YYYY" />
                </Grid.GestureRecognizers>
                <Label Text="DD/MM/YYYY" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="DdCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="True" />
                    <Label x:Name="DdUncheck" Text="○" FontSize="20" TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDateFormatSelected" CommandParameter="MM/DD/YYYY" />
                </Grid.GestureRecognizers>
                <Label Text="MM/DD/YYYY" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="MmCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />
                    <Label x:Name="MmUncheck" Text="○" FontSize="20" TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="True" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDateFormatSelected" CommandParameter="YYYY-MM-DD" />
                </Grid.GestureRecognizers>
                <Label Text="YYYY-MM-DD" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="IsoCheck" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />
                    <Label x:Name="IsoUncheck" Text="○" FontSize="20" TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="True" />
                </Grid>
            </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Time Format -->
            <Label Text="Time Format" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTimeFormatSelected" CommandParameter="12-Hour (AM/PM)" />
                </Grid.GestureRecognizers>
                <Label Text="12-Hour (AM/PM)" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="H12Check" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="True" />
                    <Label x:Name="H12Uncheck" Text="○" FontSize="20" TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />
                </Grid>
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <Grid Style="{StaticResource RowGridStyle}" ColumnDefinitions="*,Auto">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTimeFormatSelected" CommandParameter="24-Hour" />
                </Grid.GestureRecognizers>
                <Label Text="24-Hour" Style="{StaticResource RowLabelStyle}" />
                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                    <Label x:Name="H24Check" Text="●" FontSize="20" TextColor="#FC5200" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />
                    <Label x:Name="H24Uncheck" Text="○" FontSize="20" TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="True" />
                </Grid>
            </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Preview -->
            <Label Text="Preview" Style="{StaticResource SectionHeaderStyle}" />
            <Border Stroke="#243041" StrokeThickness="1" Padding="18" BackgroundColor="#111827">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <Label x:Name="PreviewLabel"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#F8FAFC"
                       HorizontalOptions="Center" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
