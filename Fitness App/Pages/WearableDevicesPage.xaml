<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.WearableDevicesPage"
             Title="Wearable Devices"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="#9E9E9E" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="16,20,16,8" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="0.5" />
            <Setter Property="Color" Value="#E0E0E0" />
            <Setter Property="Margin" Value="16,0,0,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="0,0,0,40">

            <Label Text="Paired Devices" Style="{StaticResource SectionHeaderStyle}" />
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Paired Device -->
            <Grid Padding="16,0" MinimumHeightRequest="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Text="⌚" FontSize="28" VerticalOptions="Center" Margin="0,0,12,0" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="Apple Watch Series 9" FontSize="16" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="Connected" FontSize="13" TextColor="#4CAF50" />
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="Remove"
                        Clicked="OnRemoveDevice"
                        CommandParameter="Apple Watch Series 9"
                        BackgroundColor="Transparent"
                        TextColor="#E53935"
                        BorderColor="#E53935"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="13"
                        HeightRequest="36"
                        Padding="12,0" />
            </Grid>
            <BoxView Style="{StaticResource DividerStyle}" />

            <!-- Add New Device -->
            <Button Text="+ Add New Device"
                    Clicked="OnAddDevice"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="12"
                    HeightRequest="48"
                    Margin="16,24,16,8" />

            <!-- Supported Devices Info -->
            <Border StrokeThickness="0" Padding="16,12" Margin="16,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Border.BackgroundColor>
                    <AppThemeBinding Light="#FFFFFF" Dark="#1E1E1E"/>
                </Border.BackgroundColor>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Supported devices:" FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Text="Apple Watch, Garmin, Fitbit, Samsung Galaxy Watch"
                           FontSize="13" TextColor="#9E9E9E" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
