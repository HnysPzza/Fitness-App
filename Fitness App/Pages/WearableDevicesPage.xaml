<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitness_App.Pages.WearableDevicesPage"
             Title="Wearable Devices"
             BackgroundColor="#0B0F19">

    <ContentPage.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="#64748B" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Padding" Value="0,0,0,8" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>
        <Style x:Key="DividerStyle" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="#162033" />
            <Setter Property="Margin" Value="18,0,18,0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,40" Spacing="16">

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Wearable Devices"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Pair and manage smartwatches and fitness trackers that sync activity data into the app."
                           FontSize="13"
                           TextColor="#94A3B8" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Paired Devices" Style="{StaticResource SectionHeaderStyle}" />

            <Border Padding="0"
                    BackgroundColor="#111827"
                    Stroke="#243041"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

            <!-- Paired Device -->
            <Grid Padding="18,14" MinimumHeightRequest="78">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Text="⌚" FontSize="28" VerticalOptions="Center" Margin="0,0,12,0" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="Apple Watch Series 9" FontSize="16" FontAttributes="Bold" TextColor="#F8FAFC" />
                    <Label Text="Connected" FontSize="13" TextColor="#22C55E" />
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="Remove"
                        Clicked="OnRemoveDevice"
                        CommandParameter="Apple Watch Series 9"
                        BackgroundColor="Transparent"
                        TextColor="#E53935"
                        BorderColor="#E53935"
                        BorderWidth="1"
                        CornerRadius="14"
                        FontSize="13"
                        HeightRequest="40"
                        Padding="14,0" />
            </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Add New Device -->
            <Button Text="+ Add New Device"
                    Clicked="OnAddDevice"
                    BackgroundColor="#FC5200"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="16"
                    HeightRequest="48"
                    Margin="0,8,0,0" />

            <!-- Supported Devices Info -->
            <Border Stroke="#243041" StrokeThickness="1" Padding="18" BackgroundColor="#111827">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Supported devices:" FontSize="13" FontAttributes="Bold"
                           TextColor="#F8FAFC" />
                    <Label Text="Apple Watch, Garmin, Fitbit, Samsung Galaxy Watch"
                           FontSize="13" TextColor="#94A3B8" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
